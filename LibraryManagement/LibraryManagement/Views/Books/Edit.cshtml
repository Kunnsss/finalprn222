@model LibraryManagement.Models.Book
@{
    ViewData["Title"] = "Chỉnh sửa sách";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h4><i class="fas fa-edit"></i> Chỉnh sửa sách</h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.BookId" method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="BookId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Tên sách <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="Nhập tên sách" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label">Tác giả <span class="text-danger">*</span></label>
                        <input asp-for="Author" class="form-control" placeholder="Nhập tên tác giả" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Thể loại <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" class="form-select">
                            <option value="">-- Chọn thể loại --</option>
                            @foreach (var category in ViewBag.Categories as List<LibraryManagement.Models.Category>)
                            {
                                <option value="@category.CategoryId">@category.CategoryName</option>
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ISBN" class="form-label">ISBN</label>
                        <input asp-for="ISBN" class="form-control" placeholder="Nhập mã ISBN" />
                        <span asp-validation-for="ISBN" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Publisher" class="form-label">Nhà xuất bản</label>
                        <input asp-for="Publisher" class="form-control" placeholder="Nhập nhà xuất bản" />
                        <span asp-validation-for="Publisher" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PublishedYear" class="form-label">Năm xuất bản</label>
                        <input asp-for="PublishedYear" type="number" class="form-control" placeholder="Nhập năm xuất bản" />
                        <span asp-validation-for="PublishedYear" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả sách"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    @* ==================== UPLOAD ẢNH BÌA ==================== *@
                    <div class="mb-3">
                        <label class="form-label">Ảnh bìa</label>
                        <div class="card">
                            <div class="card-body">
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="radio" name="CoverImageOption" id="optionUrl" value="url" checked onchange="toggleCoverImageOption()">
                                    <label class="form-check-label" for="optionUrl">
                                        <i class="fas fa-link"></i> Nhập URL ảnh
                                    </label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="radio" name="CoverImageOption" id="optionUpload" value="upload" onchange="toggleCoverImageOption()">
                                    <label class="form-check-label" for="optionUpload">
                                        <i class="fas fa-upload"></i> Tải ảnh lên
                                    </label>
                                </div>

                                @* URL Input *@
                                <div id="urlInputSection">
                                    <input asp-for="CoverImage" class="form-control" placeholder="Nhập URL ảnh bìa (VD: https://example.com/cover.jpg)" />
                                    <span asp-validation-for="CoverImage" class="text-danger"></span>
                                    @if (!string.IsNullOrEmpty(Model.CoverImage))
                                    {
                                        <div class="mt-2">
                                            <img src="@Model.CoverImage" class="img-thumbnail" style="max-height: 150px;" alt="Current Cover" />
                                            <small class="text-muted d-block">Ảnh hiện tại</small>
                                        </div>
                                    }
                                </div>

                                @* Upload Input *@
                                <div id="uploadInputSection" style="display: none;">
                                    <input type="file" name="CoverImageFile" class="form-control" accept="image/*" id="coverImageFile" onchange="previewUploadedImage(this)" />
                                    <small class="text-muted">Chấp nhận: .jpg, .jpeg, .png, .gif, .webp (tối đa 5MB)</small>
                                </div>

                                @* Preview *@
                                <div id="imagePreview" class="mt-3" style="display: none;">
                                    <img id="previewImg" class="img-thumbnail" style="max-height: 200px;" alt="Preview" />
                                    <small class="text-muted d-block">Ảnh mới sẽ thay thế ảnh cũ</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* ==================== LOẠI SÁCH ==================== *@
                    <input type="hidden" name="IsPhysical" id="hiddenIsPhysical" value="@(Model.IsPhysical ? "true" : "false")" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Loại sách <span class="text-danger">*</span></label>
                        <div class="card">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-6">
                                        <div class="form-check p-3 border rounded @(Model.IsPhysical ? "border-primary bg-light" : "") cursor-pointer book-type-option"
                                             id="typePhysicalCard" onclick="selectBookType('physical')">
                                            <input class="form-check-input" type="radio" name="BookTypeSelection" id="typePhysical"
                                                   value="physical" checked="@Model.IsPhysical"
                                                   onchange="toggleBookType()" />
                                            <label class="form-check-label w-100 cursor-pointer" for="typePhysical">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fas fa-box fa-2x text-primary"></i>
                                                    <div>
                                                        <strong>Sách vật lý</strong>
                                                        <div class="small text-muted">Cần nhập số lượng & giá thuê</div>
                                                    </div>
                                                </div>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="form-check p-3 border rounded @(!Model.IsPhysical ? "border-info bg-light" : "") cursor-pointer book-type-option"
                                             id="typeOnlineCard" onclick="selectBookType('online')">
                                            <input class="form-check-input" type="radio" name="BookTypeSelection" id="typeOnline"
                                                   value="online" checked="@(!Model.IsPhysical)"
                                                   onchange="toggleBookType()" />
                                            <label class="form-check-label w-100 cursor-pointer" for="typeOnline">
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="fas fa-cloud fa-2x text-info"></i>
                                                    <div>
                                                        <strong>Sách Online</strong>
                                                        <div class="small text-muted">Nhập giá & link đọc</div>
                                                    </div>
                                                </div>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="physicalBookFields">
                        <div class="mb-3">
                            <label asp-for="Quantity" class="form-label">Số lượng <span class="text-danger">*</span></label>
                            <input asp-for="Quantity" type="number" class="form-control" placeholder="Nhập số lượng" min="1" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AvailableQuantity" class="form-label">Số lượng còn lại</label>
                            <input asp-for="AvailableQuantity" type="number" class="form-control" placeholder="Nhập số lượng còn lại" />
                            <span asp-validation-for="AvailableQuantity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RentalPrice" class="form-label">Giá thuê (VND/ngày) <span class="text-danger">*</span></label>
                            <input asp-for="RentalPrice" type="number" step="0.01" class="form-control" placeholder="Nhập giá thuê" min="0" />
                            <span asp-validation-for="RentalPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="onlineBookFields" style="display: none;">
                        <div class="mb-3">
                            <label asp-for="OnlinePrice" class="form-label">Giá online (VND) <span class="text-danger">*</span></label>
                            <input asp-for="OnlinePrice" type="number" step="0.01" class="form-control" placeholder="Nhập giá online" min="0" />
                            <span asp-validation-for="OnlinePrice" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="OnlineLink" class="form-label">Link đọc sách online <span class="text-danger">*</span></label>
                            <input asp-for="OnlineLink" type="url" class="form-control" placeholder="Nhập link đọc sách (https://...)" />
                            <span asp-validation-for="OnlineLink" class="text-danger"></span>
                            <small class="form-text text-muted">
                                <i class="fas fa-info-circle"></i> Ví dụ: https://drive.google.com/... hoặc link PDF
                            </small>
                            @if (!string.IsNullOrEmpty(Model.OnlineLink))
                            {
                                <div class="mt-2">
                                    <a href="@Model.OnlineLink" target="_blank" class="btn btn-sm btn-info">
                                        <i class="fas fa-external-link-alt"></i> Xem sách hiện tại
                                    </a>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-save"></i> Cập nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function toggleCoverImageOption() {
            var optionUrl = document.getElementById('optionUrl').checked;
            document.getElementById('urlInputSection').style.display = optionUrl ? 'block' : 'none';
            document.getElementById('uploadInputSection').style.display = optionUrl ? 'none' : 'block';
        }

        function previewUploadedImage(input) {
            var preview = document.getElementById('imagePreview');
            var previewImg = document.getElementById('previewImg');

            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    previewImg.src = e.target.result;
                    preview.style.display = 'block';
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.style.display = 'none';
            }
        }

        function setSectionInputsEnabled(sectionId, enabled) {
            var section = document.getElementById(sectionId);
            if (!section) return;
            section.querySelectorAll('input:not([type="hidden"]), select, textarea').forEach(function (el) {
                el.disabled = !enabled;
            });
        }

        function toggleBookType() {
            var typePhysical = document.getElementById('typePhysical').checked;
            var physicalFields = document.getElementById('physicalBookFields');
            var onlineFields = document.getElementById('onlineBookFields');
            var physicalCard = document.getElementById('typePhysicalCard');
            var onlineCard = document.getElementById('typeOnlineCard');
            var hiddenIsPhysical = document.getElementById('hiddenIsPhysical');

            if (typePhysical) {
                physicalFields.style.display = 'block';
                onlineFields.style.display = 'none';
                setSectionInputsEnabled('physicalBookFields', true);
                setSectionInputsEnabled('onlineBookFields', false);
                if (physicalCard) physicalCard.className = 'form-check p-3 border rounded border-primary bg-light cursor-pointer book-type-option';
                if (onlineCard) onlineCard.className = 'form-check p-3 border rounded cursor-pointer book-type-option';
                if (hiddenIsPhysical) hiddenIsPhysical.value = 'true';
            } else {
                physicalFields.style.display = 'none';
                onlineFields.style.display = 'block';
                setSectionInputsEnabled('physicalBookFields', false);
                setSectionInputsEnabled('onlineBookFields', true);
                if (physicalCard) physicalCard.className = 'form-check p-3 border rounded cursor-pointer book-type-option';
                if (onlineCard) onlineCard.className = 'form-check p-3 border rounded border-info bg-light cursor-pointer book-type-option';
                if (hiddenIsPhysical) hiddenIsPhysical.value = 'false';
            }
        }

        function selectBookType(type) {
            var radio = document.getElementById(type === 'physical' ? 'typePhysical' : 'typeOnline');
            if (radio) {
                radio.checked = true;
                toggleBookType();
            }
        }

        $(document).ready(function() {
            toggleBookType();
        });
    </script>
}
