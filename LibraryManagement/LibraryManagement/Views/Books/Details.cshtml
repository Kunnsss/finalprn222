<!-- Views/Books/Details.cshtml - ĐÃ SỬA LỖI -->
@model LibraryManagement.Models.Book
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.CoverImage))
        {
            <img src="@Model.CoverImage" class="img-fluid rounded shadow" alt="@Model.Title" />
        }
        else
        {
            <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded shadow" style="height: 400px;">
                <i class="fas fa-book fa-5x"></i>
            </div>
        }

        <div class="mt-3">
            <!-- Availability Status - Cập nhật realtime -->
            <div class="alert @(Model.AvailableQuantity > 0 ? "alert-success" : "alert-danger")" id="availabilityStatus">
                <i class="fas fa-box"></i>
                <strong>
                    @if (Model.AvailableQuantity > 0)
                    {
                        <span>Còn sách</span>
                    }
                    else
                    {
                        <span>Hết sách</span>
                    }
                </strong>
                <br />
                Còn lại: <strong id="availableQty">@Model.AvailableQuantity</strong>/@Model.Quantity
            </div>

            <!-- Actions -->
            <div class="d-grid gap-2">
                @if (User.Identity.IsAuthenticated)
                {
                    @* Sách vật lý - CÒN hàng *@
                    @if (Model.IsPhysical && Model.AvailableQuantity > 0)
                    {
                        <a asp-controller="Rentals" asp-action="Rent" asp-route-bookId="@Model.BookId" class="btn btn-success">
                            <i class="fas fa-shopping-cart"></i> Thuê sách
                        </a>
                    }
                    @* Sách vật lý - HẾT hàng *@
                    else if (Model.IsPhysical && Model.AvailableQuantity == 0)
                    {
                        <div class="alert alert-warning mb-2">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Sách hiện đã hết!</strong>
                            <p class="mb-0 small">Đặt chỗ để được ưu tiên khi sách có sẵn trở lại.</p>
                        </div>
                    }
                    @* Sách Online *@
                    else if (!Model.IsPhysical)
                    {
                        <a asp-controller="OnlineRentals" asp-action="RentOnline" asp-route-bookId="@Model.BookId" class="btn btn-info">
                            <i class="fas fa-download"></i> Thuê Online
                        </a>
                    }

                    @* NÚT ĐẶT CHỖ *@
                    @if (Model.IsPhysical)
                    {
                        <form asp-controller="BookReservation" asp-action="Reserve" method="post" id="reserveForm">
                            <input type="hidden" name="bookId" value="@Model.BookId" />
                            <button type="submit"
                                    class="btn btn-warning w-100"
                                    id="btnReserve"
                                    disabled="@(Model.AvailableQuantity > 0 ? "disabled" : null)"
                                    title="@(Model.AvailableQuantity > 0 ? "Chỉ có thể đặt chỗ khi sách hết" : "Đặt chỗ ngay")">
                                <i class="fas fa-bookmark"></i> Đặt chỗ sách này
                            </button>
                        </form>
                    }
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        <a asp-controller="Account" asp-action="Login">Đăng nhập</a> để thuê hoặc đặt chỗ sách
                    </div>
                }

                @* Nút Yêu thích - LUÔN HIỂN THỊ *@
                <button class="btn btn-outline-danger" id="btnAddWishlist" data-book-id="@Model.BookId">
                    <i class="fas fa-heart"></i> Yêu thích
                </button>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <h2>@Model.Title</h2>
        <p class="text-muted">
            <i class="fas fa-user"></i> @Model.Author
            @if (Model.Category != null)
            {
                <span class="ms-3"><i class="fas fa-tag"></i> @Model.Category.CategoryName</span>
            }
        </p>

        <!-- Rating Stars -->
        <div class="mb-3">
            <div id="bookRating">
                <span class="text-warning">
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="fas fa-star"></i>
                    <i class="far fa-star"></i>
                </span>
                <span id="averageRating">0</span>
                (<span id="totalReviews">0</span> đánh giá)
            </div>
        </div>

        <!-- Thông tin chi tiết -->
        <div class="card mb-3">
            <div class="card-body">
                <h5>Thông tin chi tiết</h5>
                <table class="table">
                    <tr>
                        <th>Nhà xuất bản:</th>
                        <td>@Model.Publisher</td>
                    </tr>
                    <tr>
                        <th>Năm xuất bản:</th>
                        <td>@Model.PublishedYear</td>
                    </tr>
                    <tr>
                        <th>ISBN:</th>
                        <td>@Model.ISBN</td>
                    </tr>
                    <tr>
                        <th>Loại:</th>
                        <td>
                            @if (Model.IsPhysical)
                            {
                                <span class="badge bg-primary">Sách vật lý</span>
                                <span>Giá thuê: @Model.RentalPrice.ToString("N0") VND/ngày</span>
                            }
                            else
                            {
                                <span class="badge bg-info">Sách Online</span>
                                <span>Giá: @Model.OnlinePrice?.ToString("N0") VND</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Mô tả -->
        <div class="card mb-3">
            <div class="card-body">
                <h5>Mô tả</h5>
                <p>@Model.Description</p>
            </div>
        </div>

        <!-- Related Books -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Sách liên quan</h5>
            </div>
            <div class="card-body">
                <div id="relatedBooks" class="row">
                    <!-- Load bằng AJAX -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reviews Section -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Đánh giá từ độc giả</h5>
            </div>
            <div class="card-body">
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="mb-4">
                        <h6>Viết đánh giá của bạn</h6>
                        <div class="mb-2">
                            <label>Chấm sao:</label>
                            <div id="ratingStars">
                                <i class="far fa-star rating-star" data-rating="1"></i>
                                <i class="far fa-star rating-star" data-rating="2"></i>
                                <i class="far fa-star rating-star" data-rating="3"></i>
                                <i class="far fa-star rating-star" data-rating="4"></i>
                                <i class="far fa-star rating-star" data-rating="5"></i>
                            </div>
                            <input type="hidden" id="selectedRating" value="0" />
                        </div>
                        <textarea class="form-control mb-2" id="reviewComment" rows="3" placeholder="Nhận xét của bạn..."></textarea>
                        <button class="btn btn-primary" id="btnSubmitReview">
                            <i class="fas fa-paper-plane"></i> Gửi đánh giá
                        </button>
                    </div>
                }

                <div id="reviewsList">
                    <!-- Reviews sẽ được load ở đây -->
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const bookId = @Model.BookId;

        // ============================================
        // WISHLIST
        // ============================================
        async function addToWishlist(bookId) {
            console.log('=== ADD TO WISHLIST CALLED ===');
            console.log('BookId:', bookId);

            @if (!User.Identity.IsAuthenticated)
            {
                    <text>
                    alert('Vui lòng đăng nhập để thêm vào danh sách yêu thích');
                    window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                    return;
                    </text>
            }

            try {
                const requestBody = { bookId: bookId };
                console.log('Request body:', JSON.stringify(requestBody));

                const response = await fetch('/Wishlist/Add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(requestBody)
                });

                console.log('Response status:', response.status);
                console.log('Response ok:', response.ok);

                const result = await response.json();
                console.log('Response data:', result);

                if (result.success) {
                    showToast(result.message, 'success');
                } else {
                    showToast(result.message, 'error');
                }
            } catch (error) {
                console.error('=== FETCH ERROR ===');
                console.error('Error:', error);
                showToast('Có lỗi xảy ra khi thêm vào yêu thích', 'error');
            }
        }

        // ============================================
        // REVIEWS
        // ============================================
        async function loadReviews() {
            try {
                const response = await fetch(`/Reviews/GetBookReviews?bookId=${bookId}`);
                const data = await response.json();

                document.getElementById('averageRating').textContent = data.averageRating || 0;
                document.getElementById('totalReviews').textContent = data.totalReviews || 0;

                if (data.reviews && data.reviews.length > 0) {
                    const html = data.reviews.map(r => `
                        <div class="border-bottom pb-3 mb-3">
                            <div class="d-flex justify-content-between">
                                <strong>${r.userName}</strong>
                                <small class="text-muted">${r.reviewDate}</small>
                            </div>
                            <div class="text-warning mb-2">
                                ${'<i class="fas fa-star"></i>'.repeat(r.rating)}
                                ${'<i class="far fa-star"></i>'.repeat(5 - r.rating)}
                            </div>
                            <p>${r.comment || ''}</p>
                            <button class="btn btn-sm btn-outline-primary" onclick="markHelpful(${r.reviewId})">
                                <i class="fas fa-thumbs-up"></i> Hữu ích (${r.helpfulCount || 0})
                            </button>
                        </div>
                    `).join('');

                    document.getElementById('reviewsList').innerHTML = html;
                } else {
                    document.getElementById('reviewsList').innerHTML = '<p class="text-muted">Chưa có đánh giá nào</p>';
                }
            } catch (err) {
                console.error('Error loading reviews:', err);
            }
        }

        async function submitReview() {
            const rating = parseInt(document.getElementById('selectedRating').value);
            const comment = document.getElementById('reviewComment').value.trim();

            if (rating === 0) {
                alert('Vui lòng chọn số sao');
                return;
            }

            try {
                const formData = new FormData();
                formData.append('bookId', bookId);
                formData.append('rating', rating);
                formData.append('comment', comment);

                const response = await fetch('/Reviews/AddReview', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    document.getElementById('selectedRating').value = '0';
                    document.getElementById('reviewComment').value = '';

                    // Reset stars
                    document.querySelectorAll('.rating-star').forEach(s => {
                        s.className = 'far fa-star rating-star';
                    });

                    loadReviews();
                } else {
                    alert(result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Có lỗi xảy ra khi gửi đánh giá');
            }
        }

        async function markHelpful(reviewId) {
            try {
                const response = await fetch('/Reviews/MarkHelpful', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reviewId: reviewId })
                });

                const result = await response.json();

                if (result.success) {
                    showToast('Cảm ơn phản hồi của bạn!', 'success');
                    loadReviews();
                } else {
                    showToast(result.message, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Có lỗi xảy ra', 'error');
            }
        }

        // ============================================
        // RELATED BOOKS
        // ============================================
        async function loadRelatedBooks() {
            try {
                const response = await fetch(`/Recommendations/GetRelatedBooks?bookId=${bookId}`);
                const books = await response.json();

                if (books && books.length > 0) {
                    const html = books.map(b => `
                        <div class="col-md-3">
                            <div class="card">
                                <img src="${b.coverImage || '/images/no-cover.png'}" class="card-img-top" style="height: 150px; object-fit: cover;" />
                                <div class="card-body">
                                    <h6 class="card-title">${b.title}</h6>
                                    <a href="/Books/Details/${b.bookId}" class="btn btn-sm btn-primary w-100">Xem</a>
                                </div>
                            </div>
                        </div>
                    `).join('');

                    document.getElementById('relatedBooks').innerHTML = html;
                } else {
                    document.getElementById('relatedBooks').innerHTML = '<p class="text-muted">Không có sách liên quan</p>';
                }
            } catch (err) {
                console.error('Error loading related books:', err);
            }
        }

        // ============================================
        // SIGNALR - Sử dụng connection từ _Layout.cshtml
        // ============================================
        @if (User.Identity.IsAuthenticated)
        {
                <text>
                // Đợi SignalR connect xong từ _Layout
                setTimeout(() => {
                    if (typeof connection !== 'undefined' && connection) {
                        // Lắng nghe sự kiện cập nhật số lượng sách
                        connection.on("BookAvailabilityUpdated", function(data) {
                            if (data.bookId === bookId) {
                                console.log('Book availability updated:', data);
                                document.getElementById('availableQty').textContent = data.availableQuantity;

                                const status = document.getElementById('availabilityStatus');
                                const btnReserve = document.getElementById('btnReserve');

                                if (data.availableQuantity > 0) {
                                    status.className = 'alert alert-success';
                                    status.innerHTML = '<i class="fas fa-box"></i> <strong>Còn sách</strong><br />Còn lại: <strong id="availableQty">' + data.availableQuantity + '</strong>/@Model.Quantity';

                                    if (btnReserve) {
                                        btnReserve.disabled = true;
                                        btnReserve.title = 'Chỉ có thể đặt chỗ khi sách hết';
                                    }
                                } else {
                                    status.className = 'alert alert-danger';
                                    status.innerHTML = '<i class="fas fa-box"></i> <strong>Hết sách</strong><br />Còn lại: <strong id="availableQty">0</strong>/@Model.Quantity';

                                    if (btnReserve) {
                                        btnReserve.disabled = false;
                                        btnReserve.title = 'Đặt chỗ ngay';
                                    }
                                }
                            }
                        });
                    }
                }, 1000);
                </text>
        }

        // ============================================
        // EVENTS
        // ============================================
        document.addEventListener('DOMContentLoaded', function() {
            console.log('=== PAGE LOADED ===');
            console.log('BookId from Model:', bookId);

            // Wishlist button
            const btnWishlist = document.getElementById('btnAddWishlist');
            console.log('Wishlist button found:', btnWishlist !== null);

            if (btnWishlist) {
                const dataBookId = btnWishlist.getAttribute('data-book-id');
                console.log('Data-book-id attribute:', dataBookId);

                btnWishlist.addEventListener('click', function() {
                    console.log('=== BUTTON CLICKED ===');
                    const bookId = parseInt(this.getAttribute('data-book-id'));
                    console.log('BookId from button:', bookId);
                    addToWishlist(bookId);
                });
            }

            // Submit review button
            const btnSubmitReview = document.getElementById('btnSubmitReview');
            if (btnSubmitReview) {
                btnSubmitReview.addEventListener('click', submitReview);
            }

            // Rating stars click event
            document.querySelectorAll('.rating-star').forEach(star => {
                star.addEventListener('click', function() {
                    const rating = this.getAttribute('data-rating');
                    document.getElementById('selectedRating').value = rating;

                    document.querySelectorAll('.rating-star').forEach((s, i) => {
                        s.className = i < rating ? 'fas fa-star rating-star text-warning' : 'far fa-star rating-star';
                    });
                });
            });

            // Load initial data
            loadReviews();
            loadRelatedBooks();
        });

        // ============================================
        // TOAST NOTIFICATION
        // ============================================
        function showToast(message, type) {
            const bgColor = type === 'success' ? '#28a745' : type === 'error' ? '#dc3545' : '#17a2b8';
            const icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';

            const toast = document.createElement('div');
            toast.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: ${bgColor};
                color: white;
                padding: 15px 20px;
                border-radius: 5px;
                z-index: 9999;
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                animation: slideIn 0.3s ease-out;
            `;
            toast.innerHTML = `<i class="fas fa-${icon}"></i> ${message}`;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.5s';
                setTimeout(() => toast.remove(), 500);
            }, 3000);
        }

        // Hiển thị thông báo từ TempData
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                showToast('@TempData["SuccessMessage"]', 'success');
                </text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
                <text>
                showToast('@TempData["ErrorMessage"]', 'error');
                </text>
        }
    </script>

    <style>
        .rating-star {
            cursor: pointer;
            font-size: 1.5rem;
            transition: color 0.2s;
        }

            .rating-star:hover {
                color: #ffc107 !important;
            }

        #btnReserve:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background-color: #6c757d !important;
            border-color: #6c757d !important;
        }

            #btnReserve:disabled:hover {
                transform: none;
            }

        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
}