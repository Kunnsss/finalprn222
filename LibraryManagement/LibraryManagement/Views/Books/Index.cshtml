@model IEnumerable<LibraryManagement.Models.Book>
@{
    ViewData["Title"] = "Danh sách sách";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var totalBooks = ViewBag.TotalBooks ?? 0;
    var totalPages = ViewBag.TotalPages ?? 1;
    var currentPage = ViewBag.Page ?? 1;
    var currentBookType = ViewBag.BookType ?? "";

    string BuildUrl(int page, string? bookType = null)
    {
        var url = Url.Action("Index", "Books") + $"?page={page}";
        if (!string.IsNullOrEmpty(ViewBag.Search))
            url += $"&search={Uri.EscapeDataString(ViewBag.Search)}";
        if (ViewBag.CategoryId != null)
            url += $"&categoryId={ViewBag.CategoryId}";
        if (!string.IsNullOrEmpty(bookType))
            url += $"&bookType={bookType}";
        return url;
    }
}

<div class="lm-page-header">
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <h1 class="lm-page-title">
            Sách
            <span class="lm-count-badge" id="booksCountBadge">@totalBooks</span>
        </h1>
    </div>
    <div class="lm-toolbar ms-lg-auto">
        @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="fas fa-plus"></i> Thêm sách
            </a>
        }
        <div class="btn-group lm-view-toggle" role="group" aria-label="Chế độ xem">
            <button type="button" class="btn btn-sm btn-outline-secondary active" id="viewGridBtn" title="Lưới bìa">
                <i class="fas fa-th-large"></i>
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="viewListBtn" title="Danh sách">
                <i class="fas fa-list"></i>
            </button>
        </div>
        <select class="form-select form-select-sm lm-select-teal" id="sortBooks" aria-label="Sắp xếp">
            <option value="title">Theo tên A–Z</option>
            <option value="title-desc">Theo tên Z–A</option>
            <option value="author">Theo tác giả</option>
        </select>
        <button class="btn btn-lm-filter btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#booksFilterPanel" aria-expanded="false">
            <i class="fas fa-sliders-h"></i> Bộ lọc
        </button>
    </div>
</div>

@* ==================== TAB LỌC LOẠI SÁCH ==================== *@
<div class="d-flex align-items-center gap-2 mb-3">
    <span class="text-muted small fw-semibold">Loại sách:</span>
    <div class="btn-group btn-group-sm" role="group">
        <a href="@(Url.Action("Index", "Books")
            + (string.IsNullOrEmpty(ViewBag.Search) ? "" : "?search=" + Uri.EscapeDataString(ViewBag.Search ?? ""))
            + (ViewBag.CategoryId != null ? (string.IsNullOrEmpty(ViewBag.Search) ? "?" : "&") + $"categoryId={ViewBag.CategoryId}" : ""))"
           class="btn btn-sm @(currentBookType == "" ? "btn-primary" : "btn-outline-secondary")">
            <i class="fas fa-book"></i> Tất cả
        </a>
        <a href="@(Url.Action("Index", "Books")
            + "?bookType=physical"
            + (string.IsNullOrEmpty(ViewBag.Search) ? "" : "&search=" + Uri.EscapeDataString(ViewBag.Search ?? ""))
            + (ViewBag.CategoryId != null ? "&categoryId=" + ViewBag.CategoryId : ""))"
           class="btn btn-sm @(currentBookType == "physical" ? "btn-primary" : "btn-outline-secondary")">
            <i class="fas fa-box"></i> Sách vật lý
        </a>
        <a href="@(Url.Action("Index", "Books")
            + "?bookType=online"
            + (string.IsNullOrEmpty(ViewBag.Search) ? "" : "&search=" + Uri.EscapeDataString(ViewBag.Search ?? ""))
            + (ViewBag.CategoryId != null ? "&categoryId=" + ViewBag.CategoryId : ""))"
           class="btn btn-sm @(currentBookType == "online" ? "btn-primary" : "btn-outline-secondary")">
            <i class="fas fa-cloud"></i> Sách online
        </a>
    </div>
</div>

<form asp-action="Index" method="get" id="booksSearchForm" class="mb-3">
    @* Giữ lại bookType khi search *@
    @if (!string.IsNullOrEmpty(currentBookType))
    {
        <input type="hidden" name="bookType" value="@currentBookType" />
    }
    <div class="d-flex flex-wrap align-items-center gap-2">
        <div class="lm-search flex-grow-1" style="max-width: 100%;">
            <i class="fas fa-search"></i>
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Bắt đầu tìm kiếm…" autocomplete="off" />
        </div>
        <button type="submit" class="btn btn-outline-secondary btn-sm d-none d-md-inline-flex align-items-center gap-1">
            <i class="fas fa-search"></i> Tìm
        </button>
    </div>

    <div class="collapse lm-filter-panel mt-3" id="booksFilterPanel">
        <div class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label small text-muted mb-1">Thể loại</label>
                <select name="categoryId" class="form-select">
                    <option value="">Tất cả thể loại</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var category in ViewBag.Categories as List<LibraryManagement.Models.Category>)
                        {
                            var selectedValue = ViewBag.CategoryId != null ? ViewBag.CategoryId.ToString() : "";
                            var isSelected = category.CategoryId.ToString() == selectedValue;
                            if (isSelected)
                            {
                                <option value="@category.CategoryId" selected>@category.CategoryName</option>
                            }
                            else
                            {
                                <option value="@category.CategoryId">@category.CategoryName</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label small text-muted mb-1">Loại sách</label>
                <select name="bookType" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="physical" selected="@(currentBookType == "physical")">Sách vật lý</option>
                    <option value="online" selected="@(currentBookType == "online")">Sách online</option>
                </select>
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check"></i> Áp dụng
                </button>
            </div>
        </div>
    </div>
</form>

<div class="row g-3" id="booksContainer">
    @foreach (var book in Model)
    {
        <div class="lm-book-item col-6 col-md-4 col-xl-3"
             data-book-id="@book.BookId"
             data-sort-title="@(book.Title ?? "")"
             data-sort-author="@(book.Author ?? "")">
            <article class="lm-book-card h-100 d-flex flex-column">
                <a asp-action="Details" asp-route-id="@book.BookId" class="text-decoration-none text-dark">
                    <div class="lm-book-cover-wrap">
                        @if (!string.IsNullOrEmpty(book.CoverImage))
                        {
                            <img src="@book.CoverImage" class="lm-book-cover" alt="@book.Title" loading="lazy" />
                        }
                        else
                        {
                            <div class="lm-book-cover placeholder">
                                <i class="fas fa-book"></i>
                            </div>
                        }
                    </div>
                    <div class="lm-book-body">
                        <h2 class="lm-book-title">@book.Title</h2>
                        <p class="lm-book-author">@book.Author</p>
                        <div class="lm-book-meta">
                            @if (book.Category != null)
                            {
                                <span><i class="fas fa-tag"></i> @book.Category.CategoryName</span>
                            }
                            @if (book.IsPhysical)
                            {
                                <span class="ms-1 book-quantity" data-book-id="@book.BookId">
                                    <i class="fas fa-box"></i> Còn @book.AvailableQuantity/@book.Quantity
                                </span>
                            }
                            else
                            {
                                <span class="ms-1"><i class="fas fa-cloud"></i> Online</span>
                            }
                        </div>
                    </div>
                </a>
                <div class="lm-book-actions mt-auto">
                    <a asp-action="Details" asp-route-id="@book.BookId" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-info-circle"></i> Chi tiết
                    </a>
                    @if (User.Identity.IsAuthenticated)
                    {
                        if (book.IsPhysical)
                        {
                            if (book.AvailableQuantity > 0)
                            {
                                <a asp-controller="Rentals" asp-action="Rent" asp-route-bookId="@book.BookId" class="btn btn-sm btn-primary">
                                    <i class="fas fa-shopping-cart"></i> Thuê
                                </a>
                            }
                            else
                            {
                                <form asp-controller="BookReservation" asp-action="Reserve" method="post" class="d-inline w-100">
                                    <input type="hidden" name="bookId" value="@book.BookId" />
                                    <button type="submit" class="btn btn-sm btn-warning w-100">
                                        <i class="fas fa-bookmark"></i> Đặt chỗ
                                    </button>
                                </form>
                            }
                        }
                        else
                        {
                            <a asp-controller="OnlineRentals" asp-action="RentOnline" asp-route-bookId="@book.BookId" class="btn btn-sm btn-info text-white">
                                <i class="fas fa-download"></i> Thuê online
                            </a>
                        }
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-secondary">
                            <i class="fas fa-sign-in-alt"></i> Đăng nhập
                        </a>
                    }
                    @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                    {
                        <div class="btn-group btn-group-sm w-100">
                            <a asp-action="Edit" asp-route-id="@book.BookId" class="btn btn-outline-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@book.BookId" class="btn btn-outline-danger">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    }
                </div>
            </article>
        </div>
    }
</div>

@* ==================== PHÂN TRANG ==================== *@
@if (totalPages > 1)
{
    <nav aria-label="Phân trang sách" class="mt-4">
        <ul class="pagination justify-content-center flex-wrap gap-1">
            @{
                string PageUrl(int p) => BuildUrl(p, currentBookType);
            }
            @* Trang đầu *@
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(1)" title="Trang đầu"><i class="fas fa-angle-double-left"></i></a>
            </li>
            @* Trang trước *@
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(currentPage - 1)" title="Trang trước"><i class="fas fa-angle-left"></i></a>
            </li>

            @* Các trang *@
            @{
                int startPage = Math.Max(1, currentPage - 2);
                int endPage = Math.Min(totalPages, currentPage + 2);
                if (endPage - startPage < 4)
                {
                    if (startPage == 1) endPage = Math.Min(totalPages, startPage + 4);
                    else if (endPage == totalPages) startPage = Math.Max(1, endPage - 4);
                }
            }
            @if (startPage > 1)
            {
                <li class="page-item"><a class="page-link" href="@PageUrl(1)">1</a></li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@PageUrl(i)">@i</a>
                </li>
            }
            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item"><a class="page-link" href="@PageUrl(totalPages)">@totalPages</a></li>
            }

            @* Trang sau *@
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(currentPage + 1)" title="Trang sau"><i class="fas fa-angle-right"></i></a>
            </li>
            @* Trang cuối *@
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="@PageUrl(totalPages)" title="Trang cuối"><i class="fas fa-angle-double-right"></i></a>
            </li>
        </ul>
        <div class="text-center mt-2">
            <small class="text-muted">
                Hiển thị @(((currentPage - 1) * (ViewBag.PageSize ?? 12) + 1))–@(Math.Min(currentPage * (ViewBag.PageSize ?? 12), totalBooks)) của @totalBooks sách
                | Trang @currentPage / @totalPages
            </small>
        </div>
    </nav>
}

@if (!Model.Any())
{
    <div class="lm-empty">
        <i class="fas fa-book-open fa-3x mb-3 d-block opacity-50"></i>
        Không tìm thấy sách nào. Thử đổi từ khóa hoặc bộ lọc.
    </div>
}

@section Scripts {
    <script>
        (function () {
            const container = document.getElementById('booksContainer');
            if (!container) return;

            const items = () => Array.from(container.querySelectorAll('.lm-book-item'));
            const gridBtn = document.getElementById('viewGridBtn');
            const listBtn = document.getElementById('viewListBtn');
            const sortSel = document.getElementById('sortBooks');

            function setView(mode) {
                container.classList.toggle('lm-books-list', mode === 'list');
                gridBtn.classList.toggle('active', mode === 'grid');
                listBtn.classList.toggle('active', mode === 'list');
            }

            gridBtn?.addEventListener('click', () => setView('grid'));
            listBtn?.addEventListener('click', () => setView('list'));

            function cmp(a, b, key, desc) {
                const va = (a.dataset[key] || '').toLowerCase();
                const vb = (b.dataset[key] || '').toLowerCase();
                if (va < vb) return desc ? 1 : -1;
                if (va > vb) return desc ? -1 : 1;
                return 0;
            }

            function resort() {
                const mode = sortSel.value;
                const arr = items();
                if (mode === 'title') arr.sort((a, b) => cmp(a, b, 'sortTitle', false));
                else if (mode === 'title-desc') arr.sort((a, b) => cmp(a, b, 'sortTitle', true));
                else arr.sort((a, b) => cmp(a, b, 'sortAuthor', false));
                arr.forEach(el => container.appendChild(el));
            }

            sortSel?.addEventListener('change', resort);

            function showToast(message, type) {
                const bg = type === 'success' ? '#0d9488' : '#dc3545';
                const t = document.createElement('div');
                t.style.cssText = 'position:fixed;top:20px;right:20px;background:' + bg + ';color:#fff;padding:12px 16px;border-radius:10px;z-index:9999;box-shadow:0 8px 24px rgba(15,23,42,.15);max-width:320px;font-size:14px;';
                t.textContent = message;
                document.body.appendChild(t);
                setTimeout(() => { t.remove(); }, 3200);
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]!.ToString() ?? "")), 'success');
                </text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                showToast(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]!.ToString() ?? "")), 'error');
                </text>
            }

            // ==================== SIGNALR REALTIME ====================
            const bookConnection = new signalR.HubConnectionBuilder()
                .withUrl("/libraryHub")
                .build();

            bookConnection.on("BookAvailabilityUpdated", function (data) {
                if (!data || !data.bookId) return;

                // Update quantity badge in book card
                const qtyEl = document.querySelector(`.book-quantity[data-book-id="${data.bookId}"]`);
                if (qtyEl) {
                    qtyEl.innerHTML = `<i class="fas fa-box"></i> Còn ${data.availableQuantity}`;
                    // Add flash animation
                    qtyEl.style.transition = 'background 0.3s';
                    qtyEl.style.background = '#d1e7dd';
                    setTimeout(() => { qtyEl.style.background = ''; }, 1500);
                }

                // Update Rent button availability
                const bookCard = document.querySelector(`.lm-book-item[data-book-id="${data.bookId}"]`);
                if (bookCard) {
                    const rentBtn = bookCard.querySelector('a.btn-primary[href*="Rent"]');
                    const reserveBtn = bookCard.querySelector('form button.btn-warning');
                    if (data.availableQuantity > 0 && rentBtn) {
                        if (!rentBtn.querySelector('.fa-shopping-cart')) {
                            // Button already shows rent, do nothing
                        }
                    } else if (data.availableQuantity <= 0 && !rentBtn) {
                        // Switched to out of stock — button will re-render on page reload
                        // For instant update, check if reserve form exists
                        if (!reserveBtn) {
                            const existingForm = bookCard.querySelector('form');
                            if (existingForm) {
                                // Already has reserve form
                            } else {
                                // Would need page reload for full button swap
                            }
                        }
                    }
                }
            });

            bookConnection.start()
                .then(() => console.log('SignalR connected for Books/Index'))
                .catch(err => console.error('SignalR error:', err));
        })();
    </script>
}
