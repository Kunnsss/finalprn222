<!-- Views/OnlineRentals/MyOnlineRentals.cshtml -->
@model IEnumerable<LibraryManagement.Models.OnlineRentalTransaction>
@{
    ViewData["Title"] = "Sách Online đã thuê";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4"><i class="fas fa-laptop"></i> Sách Online đã thuê</h2>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tên sách</th>
                <th>Ngày mua</th>
                <th>Hết hạn</th>
                <th>Số tiền</th>
                <th>Thanh toán</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rental in Model)
            {
                var isExpired = rental.ExpiryDate < DateTime.Now;
                var isCancelled = rental.Status == "Cancelled";
                var rowClass = isCancelled ? "table-danger" :
                               (isExpired ? "table-secondary" :
                               (rental.PaymentStatus == "Paid" ? "table-success" : "table-warning"));

                <tr class="@rowClass">
                    <td>@rental.Book.Title</td>
                    <td>@rental.PurchaseDate.ToString("dd/MM/yyyy")</td>
                    <td>@rental.ExpiryDate.ToString("dd/MM/yyyy")</td>
                    <td><strong>@rental.Amount.ToString("N0") VND</strong></td>
                    <td>
                        @if (isCancelled)
                        {
                            <span class="badge bg-danger">Đã hủy</span>
                        }
                        else if (rental.PaymentStatus == "Paid")
                        {
                            <span class="badge bg-success">Đã thanh toán</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Chưa thanh toán</span>
                        }
                    </td>
                    <td>
                        @if (isCancelled)
                        {
                            <span class="badge bg-danger">Đã hủy</span>
                        }
                        else if (isExpired)
                        {
                            <span class="badge bg-secondary">Hết hạn</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Còn hiệu lực</span>
                        }
                    </td>
                    <td>
                        @if (isCancelled)
                        {
                            <span class="text-muted">-</span>
                        }
                        else if (rental.PaymentStatus == "Pending")
                        {
                            <a asp-action="Payment" asp-route-transactionId="@rental.OnlineTransactionId" class="btn btn-sm btn-warning">
                                <i class="fas fa-credit-card"></i> Thanh toán
                            </a>
                            <button type="button" class="btn btn-sm btn-danger" 
                                    onclick="confirmCancelOnline(@rental.OnlineTransactionId, '@rental.Book.Title')">
                                <i class="fas fa-times"></i> Hủy
                            </button>
                        }
                        else if (rental.PaymentStatus == "Paid" && !isExpired)
                        {
                            <a asp-action="AccessBook" asp-route-transactionId="@rental.OnlineTransactionId" class="btn btn-sm btn-success me-1">
                                <i class="fas fa-book-open"></i> Đọc sách
                            </a>
                            <button type="button" class="btn btn-sm btn-primary me-1" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#extendOnlineModal"
                                    data-transaction-id="@rental.OnlineTransactionId"
                                    data-book-title="@rental.Book.Title">
                                <i class="fas fa-clock"></i> Gia hạn
                            </button>
                            <button type="button" class="btn btn-sm btn-danger" 
                                    onclick="confirmCancelOnline(@rental.OnlineTransactionId, '@rental.Book.Title')">
                                <i class="fas fa-times"></i> Hủy
                            </button>
                        }
                        else if (isExpired)
                        {
                            <span class="text-muted">Đã hết hạn</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> Bạn chưa thuê sách online nào.
    </div>
}

<!-- Modal Gia hạn Online -->
<div class="modal fade" id="extendOnlineModal" tabindex="-1" aria-labelledby="extendOnlineModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="extendOnlineModalLabel">Gia hạn sách online</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="extendOnlineForm" method="post" asp-action="ExtendOnlineRental">
                <div class="modal-body">
                    <input type="hidden" id="extendOnlineTransactionId" name="transactionId" />
                    <p>Bạn muốn gia hạn sách online <strong id="extendOnlineBookTitle"></strong> thêm bao nhiêu ngày?</p>
                    
                    <div class="mb-3">
                        <label for="additionalDaysOnline" class="form-label">Số ngày gia hạn:</label>
                        <select class="form-select" id="additionalDaysOnline" name="additionalDays" required>
                            <option value="">-- Chọn số ngày --</option>
                            <option value="7">7 ngày</option>
                            <option value="14">14 ngày</option>
                            <option value="30">30 ngày</option>
                            <option value="60">60 ngày</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Xác nhận gia hạn</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Form ẩn để hủy online -->
<form id="cancelOnlineForm" method="post" asp-action="CancelOnlineRental" style="display:none;">
    <input type="hidden" id="cancelOnlineTransactionId" name="transactionId" />
</form>

<script>
    // Xử lý modal gia hạn online
    var extendOnlineModal = document.getElementById('extendOnlineModal');
    if (extendOnlineModal) {
        extendOnlineModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var transactionId = button.getAttribute('data-transaction-id');
            var bookTitle = button.getAttribute('data-book-title');
            
            document.getElementById('extendOnlineTransactionId').value = transactionId;
            document.getElementById('extendOnlineBookTitle').textContent = bookTitle;
        });
    }

    // Xử lý xác nhận hủy online
    function confirmCancelOnline(transactionId, bookTitle) {
        if (confirm('Bạn có chắc chắn muốn hủy thuê sách online "' + bookTitle + '"?')) {
            document.getElementById('cancelOnlineTransactionId').value = transactionId;
            document.getElementById('cancelOnlineForm').submit();
        }
    }

    // SignalR - Lắng nghe cập nhật online rentals
    const onlineRentalConnection = new signalR.HubConnectionBuilder()
        .withUrl("/libraryHub")
        .build();

    onlineRentalConnection.on("OnlineRentalUpdated", function () {
        // Reload trang khi có cập nhật
        location.reload();
    });

    onlineRentalConnection.start()
        .then(() => console.log('SignalR connected for online rentals'))
        .catch(err => console.error('SignalR error:', err));
</script>
@await Html.PartialAsync("_Pagination")
