@{
    ViewData["Title"] = "Gợi ý sách";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <h2 class="mb-4">
        <i class="fas fa-lightbulb"></i> Gợi ý sách dành cho bạn
    </h2>

    <!-- Loading -->
    <div id="loading" class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
        <p class="mt-3 text-muted">Đang phân tích sở thích của bạn...</p>
    </div>

    <!-- Recommendations Based on Reading History -->
    <div id="recommendationsContainer" style="display: none;">
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-star"></i> Dựa trên lịch sử đọc của bạn
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="personalizedRecommendations" class="row">
                            <!-- Loaded via AJAX -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Popular Books -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-fire"></i> Sách phổ biến
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="popularBooks" class="row">
                            <!-- Loaded via AJAX -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- New Arrivals -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-book"></i> Sách mới
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="newArrivals" class="row">
                            <!-- Loaded via AJAX -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- By Category -->
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header bg-warning">
                        <h5 class="mb-0">
                            <i class="fas fa-tags"></i> Theo thể loại bạn thích
                        </h5>
                    </div>
                    <div class="card-body">
                        <div id="categoryRecommendations" class="row">
                            <!-- Loaded via AJAX -->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- No Recommendations -->
    <div id="noRecommendations" style="display: none;">
        <div class="text-center py-5">
            <i class="fas fa-book-open fa-5x text-muted mb-4"></i>
            <h4>Chưa có đủ dữ liệu để gợi ý</h4>
            <p class="text-muted">Hãy thuê một vài cuốn sách để chúng tôi có thể gợi ý sách phù hợp với bạn!</p>
            <a href="/Books" class="btn btn-primary">
                <i class="fas fa-search"></i> Khám phá sách
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function loadRecommendations() {
            try {
                // Load personalized recommendations
                const personalizedResponse = await fetch('/Recommendations/GetPersonalized');
                const personalized = await personalizedResponse.json();
                
                if (personalized && personalized.length > 0) {
                    displayBooks(personalized, 'personalizedRecommendations');
                    document.getElementById('loading').style.display = 'none';
                    document.getElementById('recommendationsContainer').style.display = 'block';
                } else {
                    document.getElementById('loading').style.display = 'none';
                    document.getElementById('noRecommendations').style.display = 'block';
                    return;
                }

                // Load popular books
                const popularResponse = await fetch('/Recommendations/GetPopular');
                const popular = await popularResponse.json();
                displayBooks(popular, 'popularBooks');

                // Load new arrivals
                const newResponse = await fetch('/Recommendations/GetNewArrivals');
                const newBooks = await newResponse.json();
                displayBooks(newBooks, 'newArrivals');

                // Load category recommendations
                const categoryResponse = await fetch('/Recommendations/GetByFavoriteCategory');
                const categoryBooks = await categoryResponse.json();
                displayBooks(categoryBooks, 'categoryRecommendations');

            } catch (error) {
                console.error('Error loading recommendations:', error);
                document.getElementById('loading').innerHTML = `
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle"></i> Có lỗi khi tải gợi ý sách
                    </div>
                `;
            }
        }

        function displayBooks(books, containerId) {
            const container = document.getElementById(containerId);
            
            if (!books || books.length === 0) {
                container.innerHTML = '<p class="text-muted">Không có sách nào</p>';
                return;
            }

            let html = '';
            books.forEach(book => {
                html += `
                    <div class="col-md-3 mb-4">
                        <div class="card h-100 shadow-sm">
                            <img src="${book.coverImage || '/images/no-cover.png'}" 
                                 class="card-img-top" 
                                 style="height: 250px; object-fit: cover;" 
                                 alt="${book.title}">
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title">${book.title}</h6>
                                <p class="card-text text-muted small">${book.author}</p>
                                ${book.averageRating ? `
                                    <div class="mb-2">
                                        <span class="text-warning">
                                            ${getStars(book.averageRating)}
                                        </span>
                                        <small class="text-muted">(${book.averageRating.toFixed(1)})</small>
                                    </div>
                                ` : ''}
                                ${book.matchReason ? `
                                    <small class="text-success mb-2">
                                        <i class="fas fa-check-circle"></i> ${book.matchReason}
                                    </small>
                                ` : ''}
                                <div class="mt-auto">
                                    <a href="/Books/Details/${book.bookId}" class="btn btn-primary btn-sm w-100">
                                        <i class="fas fa-eye"></i> Xem chi tiết
                                    </a>
                                    ${book.availableQuantity > 0 || !book.isPhysical ? `
                                        <button class="btn btn-success btn-sm w-100 mt-2" onclick="quickRent(${book.bookId}, ${book.isPhysical})">
                                            <i class="fas fa-shopping-cart"></i> Thuê ngay
                                        </button>
                                    ` : `
                                        <button class="btn btn-secondary btn-sm w-100 mt-2" disabled>
                                            <i class="fas fa-times"></i> Hết sách
                                        </button>
                                    `}
                                    <button class="btn btn-outline-danger btn-sm w-100 mt-2" onclick="addToWishlist(${book.bookId})">
                                        <i class="fas fa-heart"></i> Yêu thích
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;
        }

        function getStars(rating) {
            const fullStars = Math.floor(rating);
            const hasHalfStar = rating % 1 >= 0.5;
            let stars = '';

            for (let i = 0; i < fullStars; i++) {
                stars += '<i class="fas fa-star"></i>';
            }
            if (hasHalfStar) {
                stars += '<i class="fas fa-star-half-alt"></i>';
            }
            for (let i = fullStars + (hasHalfStar ? 1 : 0); i < 5; i++) {
                stars += '<i class="far fa-star"></i>';
            }

            return stars;
        }

        function quickRent(bookId, isPhysical) {
            if (isPhysical) {
                window.location.href = `/Rentals/Rent?bookId=${bookId}`;
            } else {
                window.location.href = `/OnlineRentals/RentOnline?bookId=${bookId}`;
            }
        }

        async function addToWishlist(bookId) {
            try {
                const response = await fetch('/Wishlist/Add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ bookId: bookId })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showToast(result.message, 'success');
                } else {
                    showToast(result.message, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Có lỗi xảy ra khi thêm vào yêu thích', 'error');
            }
        }

        function showToast(message, type) {
            const bgColor = type === 'success' ? '#28a745' : type === 'error' ? '#dc3545' : '#17a2b8';
            const icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';

            const toast = document.createElement('div');
            toast.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: ${bgColor};
                color: white;
                padding: 15px 20px;
                border-radius: 5px;
                z-index: 9999;
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
                animation: slideIn 0.3s ease-out;
            `;
            toast.innerHTML = `<i class="fas fa-${icon}"></i> ${message}`;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.5s';
                setTimeout(() => toast.remove(), 500);
            }, 3000);
        }

        // Load on page load
        document.addEventListener('DOMContentLoaded', loadRecommendations);
    </script>

    <style>
        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .card {
            transition: transform 0.2s;
        }

        .card:hover {
            transform: translateY(-5px);
        }
    </style>
}
