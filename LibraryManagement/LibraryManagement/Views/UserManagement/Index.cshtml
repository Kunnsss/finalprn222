@* Views/UserManagement/Index.cshtml *@
@model List<LibraryManagement.ViewModels.UserManagementViewModel>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as List<LibraryManagement.Models.Role>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2><i class="fas fa-users"></i> Quản lý tài khoản</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="breadcrumb-item active">Quản lý tài khoản</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-list"></i> Danh sách người dùng</h5>
                <a asp-action="Create" class="btn btn-light btn-sm">
                    <i class="fas fa-plus"></i> Thêm mới
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Bộ lọc và tìm kiếm -->
            <form method="get" class="mb-4">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-search"></i></span>
                            <input type="text" name="searchString" class="form-control"
                                   placeholder="Tìm theo tên, username, email..."
                                   value="@ViewBag.SearchString">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select name="roleFilter" class="form-select">
                            <option value="">-- Tất cả vai trò --</option>
                            @if (roles != null)
                            {
                                @foreach (var role in roles)
                                {
                                    <option value="@role.RoleId" selected="@(ViewBag.RoleFilter == role.RoleId)">
                                        @role.RoleName
                                    </option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select name="statusFilter" class="form-select">
                            <option value="">-- Tất cả trạng thái --</option>
                            <option value="true" selected="@(ViewBag.StatusFilter == true)">Hoạt động</option>
                            <option value="false" selected="@(ViewBag.StatusFilter == false)">Bị khóa</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter"></i> Lọc
                        </button>
                    </div>
                </div>
            </form>

            <!-- Bảng danh sách -->
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Tên đăng nhập</th>
                            <th>Họ và tên</th>
                            <th>Email</th>
                            <th>Số điện thoại</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@user.UserId</td>
                                    <td><strong>@user.Username</strong></td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>@(user.PhoneNumber ?? "N/A")</td>
                                    <td>
                                        @if (user.RoleName == "Admin")
                                        {
                                            <span class="badge bg-danger">@user.RoleName</span>
                                        }
                                        else if (user.RoleName == "Staff")
                                        {
                                            <span class="badge bg-warning">@user.RoleName</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">@user.RoleName</span>
                                        }
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge bg-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Bị khóa</span>
                                        }
                                    </td>
                                    <td>@user.CreatedDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@user.UserId"
                                               class="btn btn-sm btn-info" title="Chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@user.UserId"
                                               class="btn btn-sm btn-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="ChangePassword" asp-route-id="@user.UserId"
                                               class="btn btn-sm btn-primary" title="Đổi mật khẩu">
                                                <i class="fas fa-key"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger btn-delete"
                                                    data-user-id="@user.UserId"
                                                    data-username="@user.Username"
                                                    title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                    Không có dữ liệu
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Thống kê -->
            <div class="mt-3">
                <p class="text-muted">
                    <i class="fas fa-info-circle"></i>
                    Tổng số: <strong>@(Model?.Count ?? 0)</strong> người dùng
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal - Single instance -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Xác nhận xóa</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Bạn có chắc chắn muốn xóa người dùng <strong id="deleteUsername"></strong>?</p>
                <p class="text-muted">
                    <small>
                        <i class="fas fa-info-circle"></i>
                        Nếu người dùng có giao dịch, tài khoản sẽ bị vô hiệu hóa thay vì xóa hoàn toàn.
                    </small>
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form id="deleteForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto dismiss alerts
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);

        // Handle delete button click
        document.addEventListener('DOMContentLoaded', function() {
            // Get all delete buttons
            const deleteButtons = document.querySelectorAll('.btn-delete');
            const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
            const deleteForm = document.getElementById('deleteForm');
            const deleteUsername = document.getElementById('deleteUsername');

            deleteButtons.forEach(button => {
                button.addEventListener('click', function() {
                    const userId = this.getAttribute('data-user-id');
                    const username = this.getAttribute('data-username');

                    // Update modal content
                    deleteUsername.textContent = username;

                    // Update form action
                    deleteForm.action = '@Url.Action("Delete", "UserManagement")/' + userId;

                    // Show modal
                    deleteModal.show();
                });
            });
        });
    </script>
}
