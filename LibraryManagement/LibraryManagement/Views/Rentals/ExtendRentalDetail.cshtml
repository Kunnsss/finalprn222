@model LibraryManagement.Models.RentalTransaction
@{
    int additionalDays = ViewBag.AdditionalDays;
    decimal extensionFee = ViewBag.ExtensionFee;
    DateTime newDueDate = ViewBag.NewDueDate;
    ViewData["Title"] = "Xác nhận gia hạn sách";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><i class="fas fa-clock"></i> Xác nhận gia hạn sách</h4>
            </div>
            <div class="card-body">

                <!-- Book info -->
                <div class="d-flex align-items-center mb-4">
                    <div class="me-3">
                        <i class="fas fa-book fa-3x text-secondary"></i>
                    </div>
                    <div>
                        <h5 class="mb-1">@Model.Book.Title</h5>
                        <span class="badge bg-primary">Mã giao dịch #@Model.TransactionId</span>
                    </div>
                </div>

                <hr />

                <!-- Extend details -->
                <table class="table table-borderless">
                    <tbody>
                        <tr>
                            <td class="text-muted">Ngày thuê</td>
                            <td><strong>@Model.RentalDate.ToString("dd/MM/yyyy")</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Hạn trả hiện tại</td>
                            <td>
                                <strong class="@(Model.DueDate < DateTime.Now ? "text-danger" : "")">
                                    @Model.DueDate.ToString("dd/MM/yyyy")
                                </strong>
                                @if (Model.DueDate < DateTime.Now)
                                {
                                    <span class="badge bg-danger ms-1">Quá hạn</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Số ngày gia hạn</td>
                            <td><strong>+@additionalDays ngày</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Hạn trả mới</td>
                            <td><strong class="text-success">@newDueDate.ToString("dd/MM/yyyy")</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Giá thuê / ngày</td>
                            <td>@Model.RentalPrice.ToString("N0") VND</td>
                        </tr>
                        <tr class="table-active">
                            <td><strong>Phí gia hạn</strong></td>
                            <td><strong class="text-success fs-5">@extensionFee.ToString("N0") VND</strong></td>
                        </tr>
                    </tbody>
                </table>

                <hr />

                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i>
                    Sau khi thanh toán thành công, hạn trả sách sẽ được cập nhật ngay lập tức.
                </div>

                <!-- PayOS payment form -->
                <form asp-action="InitiateExtendPayment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="transactionId" value="@Model.TransactionId" />
                    <input type="hidden" name="additionalDays" value="@additionalDays" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-credit-card"></i> Thanh toán bằng PayOS
                        </button>
                        <a asp-action="MyRentals" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>
