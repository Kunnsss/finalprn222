@model LibraryManagement.Models.AllRentalsViewModel
@{
    ViewData["Title"] = "Quản lý thuê sách";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Custom alert styling */
    .alert {
        border-left: 4px solid;
        border-radius: 8px;
        animation: slideInDown 0.3s ease-out;
    }

    .alert-success {
        border-left-color: #198754;
        background-color: #d1e7dd;
    }

    .alert-danger {
        border-left-color: #dc3545;
        background-color: #f8d7da;
    }

    .alert-info {
        border-left-color: #0dcaf0;
        background-color: #cff4fc;
    }

    .alert .alert-heading {
        font-weight: 600;
        font-size: 1.1rem;
    }

    @@keyframes slideInDown {
        from {
            transform: translateY(-20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    /* Fade out animation */
    .alert.fade-out {
        animation: fadeOut 0.5s ease-out forwards;
    }

    @@keyframes fadeOut {
        from {
            opacity: 1;
        }

        to {
            opacity: 0;
            transform: translateY(-10px);
        }
    }

    /* Card shadow improvements */
    .card.shadow-sm {
        box-shadow: 0 0.125rem 0.5rem rgba(0, 0, 0, 0.1);
    }

    /* Table improvements */
    .table-hover tbody tr:hover {
        background-color: rgba(0, 0, 0, 0.03);
        transition: background-color 0.2s ease;
    }

    /* Custom confirmation modal */
    .custom-confirm-modal .modal-content {
        border-radius: 15px;
        border: none;
        box-shadow: 0 5px 20px rgba(0,0,0,0.3);
    }

    .custom-confirm-modal .modal-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 15px 15px 0 0;
        border: none;
    }

    .custom-confirm-modal .modal-body {
        padding: 30px;
        font-size: 1.1rem;
    }

    .custom-confirm-modal .btn-custom-confirm {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        padding: 10px 30px;
        border-radius: 25px;
        color: white;
        font-weight: 600;
    }

    .custom-confirm-modal .btn-custom-cancel {
        background: #6c757d;
        border: none;
        padding: 10px 30px;
        border-radius: 25px;
        color: white;
        font-weight: 600;
    }
</style>

<div class="row mb-4">
    <div class="col-md-8">
        <h2><i class="fas fa-clipboard-list"></i> Quản lý tất cả giao dịch thuê sách</h2>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="OverdueRentals" class="btn btn-danger">
            <i class="fas fa-exclamation-triangle"></i> Sách quá hạn
        </a>
    </div>
</div>

