@if (TempData["ErrorMessage"] != null)
{
    var message = TempData["ErrorMessage"].ToString();
    // Loại bỏ localhost URLs khỏi thông báo
    message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
    message = message.Trim();

    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <div class="d-flex align-items-center">
            <div class="flex-shrink-0">
                <i class="fas fa-exclamation-circle fa-2x me-3"></i>
            </div>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-1">Có lỗi xảy ra!</h5>
                <p class="mb-0">@message</p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

@if (TempData["InfoMessage"] != null)
{
    var message = TempData["InfoMessage"].ToString();
    // Loại bỏ localhost URLs khỏi thông báo
    message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
    message = message.Trim();

    <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
        <div class="d-flex align-items-center">
            <div class="flex-shrink-0">
                <i class="fas fa-info-circle fa-2x me-3"></i>
            </div>
            <div class="flex-grow-1">
                <h5 class="alert-heading mb-1">Thông báo</h5>
                <p class="mb-0">@message</p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<!-- Custom Confirmation Modal -->
<div class="modal fade custom-confirm-modal" id="confirmReturnModal" tabindex="-1" aria-labelledby="confirmReturnModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmReturnModalLabel">
                    <i class="fas fa-question-circle"></i> Xác nhận nhận sách trả về
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <i class="fas fa-book-reader fa-3x text-primary mb-3"></i>
                <p class="mb-0">Bạn có chắc chắn đã nhận sách trả về?</p>
                <small class="text-muted">Hành động này không thể hoàn tác</small>
            </div>
            <div class="modal-footer justify-content-center border-0">
                <button type="button" class="btn btn-custom-cancel" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Hủy
                </button>
                <button type="button" class="btn btn-custom-confirm" id="confirmReturnBtn">
                    <i class="fas fa-check"></i> Xác nhận
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Xử lý sách mất — nhập tiền đền bù -->
<div class="modal fade" id="processLostModal" tabindex="-1" aria-labelledby="processLostModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="processLostModalLabel">
                    <i class="fas fa-book-dead"></i> Xử lý sách mất — phí đền bù
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ProcessLostCompensation" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="processLostTransactionId" name="transactionId" />
                <div class="modal-body">
                    <p class="mb-2">Giao dịch: <strong id="processLostTxLabel"></strong></p>
                    <p class="small text-muted mb-3">Số tiền nhập sẽ được cộng vào <strong>Phí phạt</strong> và <strong>Tổng tiền</strong>. Trạng thái chuyển sang <strong>Chờ thanh toán</strong> (user và admin).</p>
                    <div class="mb-3">
                        <label for="compensationAmount" class="form-label">Số tiền đền bù (VND) <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="compensationAmount" name="compensationAmount"
                               min="1" step="1" required placeholder="Ví dụ: 15000" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-dark">
                        <i class="fas fa-check"></i> Lưu &amp; chờ thanh toán
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-3" id="rentalTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="offline-tab" data-bs-toggle="tab" data-bs-target="#offline" type="button">
            <i class="fas fa-book"></i> Thuê trực tiếp (@Model.OfflineRentals.Count())
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="online-tab" data-bs-toggle="tab" data-bs-target="#online" type="button">
            <i class="fas fa-cloud"></i> Thuê online (@Model.OnlineRentals.Count())
        </button>
    </li>
</ul>

<div class="tab-content" id="rentalTabContent">
    <!-- Tab: Thuê trực tiếp -->
    <div class="tab-pane fade show active" id="offline" role="tabpanel">
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-book"></i> Giao dịch thuê trực tiếp</h5>
            </div>
            <div class="card-body">
                @if (Model.OfflineRentals.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>Mã GD</th>
                                    <th>Người thuê</th>
                                    <th>Sách</th>
                                    <th>Ngày thuê</th>
                                    <th>Hạn trả</th>
                                    <th>Ngày trả</th>
                                    <th>Số ngày</th>
                                    <th>Tổng tiền</th>
                                    <th>Phí phạt</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rental in Model.OfflineRentals)
                                {
                                    var isLost = rental.Status == "Lost";
                                    var isCompensated = rental.Status == "Compensated";
                                    var isReturned = rental.Status == "Returned" || isCompensated;
                                    var isClosed = isReturned || isLost;
                                    var isOverdue = rental.Status != "PendingPayment" && !isClosed && rental.DueDate < DateTime.Now;
                                    var rowClass = isLost ? "table-secondary" : (isCompensated ? "table-success" : (isOverdue ? "table-danger" : (rental.Status == "Returned" ? "" : "table-warning")));

                                    <tr class="@rowClass" data-transaction-id="@rental.TransactionId">
                                        <td><strong>#@rental.TransactionId</strong></td>
                                        <td>
                                            <i class="fas fa-user"></i> @rental.User?.FullName
                                            <br />
                                            <small class="text-muted">@rental.User?.Email</small>
                                        </td>
                                        <td>
                                            <i class="fas fa-book"></i> @rental.Book?.Title
                                            <br />
                                            <small class="text-muted">@rental.Book?.Author</small>
                                        </td>
                                        <td>
                                            <i class="far fa-calendar-alt"></i>
                                            @rental.RentalDate.ToString("dd/MM/yyyy")
                                            <br />
                                            <small class="text-muted">@rental.RentalDate.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            <i class="far fa-calendar-check"></i>
                                            @rental.DueDate.ToString("dd/MM/yyyy")
                                            @if (isOverdue)
                                            {
                                                <br />
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-exclamation-triangle"></i> Quá hạn
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (rental.ReturnDate.HasValue)
                                            {
                                                <i class="far fa-calendar-times"></i>
                                                @rental.ReturnDate.Value.ToString("dd/MM/yyyy")
                                                <br />
                                                <small class="text-muted">@rental.ReturnDate.Value.ToString("HH:mm")</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Chưa trả</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (rental.RentalDays > 0)
                                            {
                                                <span class="badge bg-info">@rental.RentalDays ngày</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            <strong class="text-primary">@rental.TotalAmount.ToString("N0") đ</strong>
                                        </td>
                                        <td>
                                            @if (rental.LateFee > 0)
                                            {
                                                <strong class="text-danger">@rental.LateFee.ToString("N0") đ</strong>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0 đ</span>
                                            }
                                            </td>
                                        <td class="status-badge">
                                            @if (rental.Status == "PendingPayment")
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="fas fa-clock"></i> Chờ thanh toán
                                                </span>
                                            }
                                            else if (rental.Status == "Cancelled")
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="fas fa-ban"></i> Đã hủy
                                                </span>
                                            }
                                            else if (rental.Status == "Returned")
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check"></i> Đã trả
                                                </span>
                                            }
                                            else if (isCompensated)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check-double"></i> Đã đền bù
                                                </span>
                                            }
                                            else if (isLost)
                                            {
                                                <span class="badge bg-dark" title="Người thuê đã báo mất sách">
                                                    <i class="fas fa-book-dead"></i> Đã báo mất
                                                </span>
                                            }
                                            else if (isOverdue)
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-clock"></i> Quá hạn
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="fas fa-hourglass-half"></i> Đang thuê
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (rental.Status == "PendingPayment")
                                            {
                                                <form asp-action="ConfirmPayment" method="post" style="display:inline;">
                                                    <input type="hidden" name="transactionId" value="@rental.TransactionId" />
                                                    <button type="submit" class="btn btn-sm btn-primary">
                                                        <i class="fas fa-check-circle"></i> Xác nhận thanh toán
                                                    </button>
                                                </form>
                                            }
                                            else if (rental.Status == "Cancelled")
                                            {
                                                <span class="text-muted">Đã hủy</span>
                                            }
                                            else if (isLost)
                                            {
                                                <button type="button" class="btn btn-sm btn-dark btn-process-lost"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#processLostModal"
                                                        data-transaction-id="@rental.TransactionId"
                                                        data-tx-label="Mã GD #@rental.TransactionId">
                                                    <i class="fas fa-cog"></i> Xử lý
                                                </button>
                                            }
                                            else if (rental.Status != "Returned" && !isCompensated)
                                            {
                                                <form asp-action="Return" method="post" style="display:inline;" class="return-form" data-transaction-id="@rental.TransactionId">
                                                    <input type="hidden" name="transactionId" value="@rental.TransactionId" />
                                                    <button type="button" class="btn btn-sm btn-success btn-return">
                                                        <i class="fas fa-undo"></i> Nhận trả
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle fa-2x mb-2"></i>
                        <p class="mb-0">Chưa có giao dịch thuê trực tiếp nào</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Tab: Thuê online -->
    <div class="tab-pane fade" id="online" role="tabpanel">
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="fas fa-cloud"></i> Giao dịch thuê online</h5>
            </div>
            <div class="card-body">
                @if (Model.OnlineRentals.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>Mã GD</th>
                                    <th>Người thuê</th>
                                    <th>Sách</th>
                                    <th>Ngày mua</th>
                                    <th>Ngày hết hạn</th>
                                    <th>Số ngày</th>
                                    <th>Số tiền</th>
                                    <th>Thanh toán</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rental in Model.OnlineRentals)
                                {
                                    var isExpired = rental.IsExpired();
                                    var rowClass = isExpired ? "table-danger" : (rental.Status == "Expired" ? "table-secondary" : "table-success");
                                    var rentalDays = rental.GetRentalDays();

                                    <tr class="@rowClass">
                                        <td><strong>@rental.OnlineTransactionId</strong></td>
                                        <td>
                                            <i class="fas fa-user"></i> @rental.User?.FullName
                                            <br />
                                            <small class="text-muted">@rental.User?.Email</small>
                                        </td>
                                        <td>
                                            <i class="fas fa-book"></i> @rental.Book?.Title
                                            <br />
                                            <small class="text-muted">@rental.Book?.Author</small>
                                        </td>
                                        <td>
                                            <i class="far fa-calendar-alt"></i>
                                            @rental.PurchaseDate.ToString("dd/MM/yyyy")
                                            <br />
                                            <small class="text-muted">@rental.PurchaseDate.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            <i class="far fa-calendar-check"></i>
                                            @rental.ExpiryDate.ToString("dd/MM/yyyy")
                                            @if (isExpired)
                                            {
                                                <br />
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-exclamation-triangle"></i> Hết hạn
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (rentalDays > 0)
                                            {
                                                <span class="badge bg-info">@rentalDays ngày</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            <strong class="text-primary">@rental.Amount.ToString("N0") đ</strong>
                                        </td>
                                        <td>
                                            @if (rental.PaymentStatus == "Paid")
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check-circle"></i> Đã thanh toán
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="fas fa-clock"></i> Chờ thanh toán
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (rental.Status == "Cancelled")
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-ban"></i> Đã hủy
                                                </span>
                                            }
                                            else if (rental.Status == "Active")
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check"></i> Đang hoạt động
                                                </span>
                                            }
                                            else if (rental.Status == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="fas fa-clock"></i> Chờ xác nhận
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    <i class="fas fa-times"></i> Đã hết hạn
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (rental.PaymentStatus == "Pending" && rental.Status != "Cancelled")
                                            {
                                                <form asp-controller="OnlineRentals" asp-action="ProcessPayment" method="post" style="display:inline;">
                                                    <input type="hidden" name="transactionId" value="@rental.OnlineTransactionId" />
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="fas fa-check-circle"></i> Xác nhận thanh toán
                                                    </button>
                                                </form>
                                            }
                                            else if (rental.Status == "Cancelled")
                                            {
                                                <span class="text-muted">Đã hủy</span>
                                            }
                                            else if (rental.PaymentStatus == "Paid" && !string.IsNullOrEmpty(rental.AccessLink))
                                            {
                                                <a href="@rental.AccessLink" class="btn btn-sm btn-primary" target="_blank">
                                                    <i class="fas fa-external-link-alt"></i> Truy cập
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle fa-2x mb-2"></i>
                        <p class="mb-0">Chưa có giao dịch thuê online nào</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Thống kê -->
<div class="row mt-4">
    <div class="col-md-12">
        <div class="card bg-light shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3"><i class="fas fa-chart-bar"></i> Thống kê tổng hợp</h5>
                <div class="row text-center">
                    <div class="col-md-3">
                        <h6>Tổng giao dịch</h6>
                        <h3 class="text-primary">@(Model.OfflineRentals.Count() + Model.OnlineRentals.Count())</h3>
                    </div>
                    <div class="col-md-3">
                        <h6>Thuê trực tiếp</h6>
                        <h3 class="text-info">@Model.OfflineRentals.Count()</h3>
                    </div>
                    <div class="col-md-3">
                        <h6>Thuê online</h6>
                        <h3 class="text-info">@Model.OnlineRentals.Count()</h3>
                    </div>
                    <div class="col-md-3">
                        <h6>Đang hoạt động</h6>
                        <h3 class="text-success">
                            @(Model.OfflineRentals.Count(r => r.Status != "Returned" && r.Status != "Lost" && r.Status != "Compensated") + Model.OnlineRentals.Count(r => r.Status == "Active"))
                        </h3>
                    </div>
                </div>
                <hr />
                <div class="row text-center">
                    <div class="col-md-4">
                        <h6>Doanh thu trực tiếp</h6>
                        <h3 class="text-success">@Model.OfflineRentals.Sum(r => r.TotalAmount).ToString("N0") đ</h3>
                    </div>
                    <div class="col-md-4">
                        <h6>Doanh thu online</h6>
                        <h3 class="text-success">@Model.OnlineRentals.Sum(r => r.Amount).ToString("N0") đ</h3>
                    </div>
                    <div class="col-md-4">
                        <h6>Tổng phí phạt</h6>
                        <h3 class="text-danger">@Model.OfflineRentals.Sum(r => r.LateFee).ToString("N0") đ</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentForm = null;

        // ==================== TOAST NOTIFICATION SYSTEM ====================
        function showRealtimeToast(message, type = 'info') {
            const id = 'realtimeToast_' + Date.now();
            const bg = type === 'success' ? '#198754' : type === 'danger' ? '#dc3545' : type === 'warning' ? '#ffc107' : '#0dcaf0';
            const icon = type === 'success' ? 'fa-check-circle' : type === 'danger' ? 'fa-exclamation-circle' : type === 'warning' ? 'fa-exclamation-triangle' : 'fa-info-circle';
            const t = document.createElement('div');
            t.id = id;
            t.style.cssText = `position:fixed;top:20px;right:20px;background:${bg};color:#fff;padding:14px 18px;border-radius:10px;z-index:99999;box-shadow:0 8px 24px rgba(0,0,0,.2);max-width:360px;font-size:14px;display:flex;align-items:center;gap:10px;animation:slideInRight .3s ease`;
            t.innerHTML = `<i class="fas ${icon}"></i><span>${message}</span>`;
            document.body.appendChild(t);
            setTimeout(() => {
                t.style.animation = 'fadeOutLeft .3s ease forwards';
                setTimeout(() => t.remove(), 300);
            }, 4000);
        }

        // ==================== ROW UPDATE HELPERS ====================
        function updateOfflineRowStatus(transactionId, status) {
            const row = document.querySelector(`tr[data-transaction-id="${transactionId}"]`);
            if (!row) return;

            // Update row class
            row.className = row.className.replace(/table-\w+/g, '').trim();
            if (status === 'Lost') row.classList.add('table-secondary');
            else if (status === 'Returned' || status === 'Compensated') row.classList.add('table-success');
            else if (status === 'Overdue') row.classList.add('table-danger');
            else if (status === 'Cancelled') row.classList.add('table-secondary');
            else row.classList.add('table-warning');

            // Update status badge
            const statusCell = row.querySelector('.status-badge');
            if (statusCell) {
                const badgeMap = {
                    'PendingPayment': '<span class="badge bg-warning text-dark"><i class="fas fa-clock"></i> Chờ thanh toán</span>',
                    'Cancelled': '<span class="badge bg-secondary"><i class="fas fa-ban"></i> Đã hủy</span>',
                    'Returned': '<span class="badge bg-success"><i class="fas fa-check"></i> Đã trả</span>',
                    'Compensated': '<span class="badge bg-success"><i class="fas fa-check-double"></i> Đã đền bù</span>',
                    'Lost': '<span class="badge bg-dark"><i class="fas fa-book-dead"></i> Đã báo mất</span>',
                    'Overdue': '<span class="badge bg-danger"><i class="fas fa-clock"></i> Quá hạn</span>',
                    'Renting': '<span class="badge bg-warning text-dark"><i class="fas fa-hourglass-half"></i> Đang thuê</span>'
                };
                statusCell.innerHTML = badgeMap[status] || `<span class="badge bg-secondary">${status}</span>`;
            }

            // Update actions column
            const actionsCell = row.querySelector('td:last-child');
            if (actionsCell) {
                if (status === 'Lost') {
                    actionsCell.innerHTML = `<button type="button" class="btn btn-sm btn-dark btn-process-lost"
                            data-bs-toggle="modal" data-bs-target="#processLostModal"
                            data-transaction-id="${transactionId}" data-tx-label="Mã GD #${transactionId}">
                        <i class="fas fa-cog"></i> Xử lý</button>`;
                } else if (status === 'PendingPayment') {
                    actionsCell.innerHTML = `<form asp-action="ConfirmPayment" method="post" style="display:inline;">
                            <input type="hidden" name="transactionId" value="${transactionId}" />
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="fas fa-check-circle"></i> Xác nhận thanh toán</button></form>`;
                } else if (status === 'Returned' || status === 'Compensated') {
                    actionsCell.innerHTML = '<span class="text-muted">-</span>';
                } else if (status !== 'Cancelled') {
                    actionsCell.innerHTML = `<form asp-action="Return" method="post" style="display:inline;" class="return-form" data-transaction-id="${transactionId}">
                            <input type="hidden" name="transactionId" value="${transactionId}" />
                            <button type="button" class="btn btn-sm btn-success btn-return">
                                <i class="fas fa-undo"></i> Nhận trả</button></form>`;
                }
            }

            // Re-attach return button handler
            row.querySelector('.btn-return')?.addEventListener('click', function(e) {
                e.preventDefault();
                currentForm = $(this).closest('.return-form');
                $('#confirmReturnModal').modal('show');
            });
        }

        function updateLateFeeCell(transactionId, lateFee) {
            const row = document.querySelector(`tr[data-transaction-id="${transactionId}"]`);
            if (!row) return;
            const lateFeeCell = row.querySelector('td:nth-child(9)');
            if (lateFeeCell) {
                lateFeeCell.innerHTML = lateFee > 0
                    ? `<strong class="text-danger">${Number(lateFee).toLocaleString('vi-VN')} đ</strong>`
                    : '<span class="text-muted">0 đ</span>';
            }
        }

        // ==================== AUTO-HIDE ALERTS ====================
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').addClass('fade-out');
                setTimeout(function() {
                    $('.alert').alert('close');
                }, 500);
            }, 6000);

            $('.alert').on('click', function() {
                $(this).addClass('fade-out');
                var alert = $(this);
                setTimeout(function() {
                    alert.alert('close');
                }, 500);
            });

            $('.btn-return').on('click', function(e) {
                e.preventDefault();
                currentForm = $(this).closest('.return-form');
                $('#confirmReturnModal').modal('show');
            });

            $('#confirmReturnBtn').on('click', function() {
                if (currentForm) {
                    $('#confirmReturnModal').modal('hide');
                    currentForm.submit();
                }
            });

            var processLostModal = document.getElementById('processLostModal');
            if (processLostModal) {
                processLostModal.addEventListener('show.bs.modal', function (event) {
                    var btn = event.relatedTarget;
                    if (!btn) return;
                    document.getElementById('processLostTransactionId').value = btn.getAttribute('data-transaction-id') || '';
                    document.getElementById('processLostTxLabel').textContent = btn.getAttribute('data-tx-label') || '';
                    var amt = document.getElementById('compensationAmount');
                    if (amt) amt.value = '';
                });
            }
        });

        // ==================== SIGNALR REALTIME ====================
        const adminRentalConnection = new signalR.HubConnectionBuilder()
            .withUrl("/libraryHub")
            .build();

        // Khi có thay đổi rental (trả, hủy, gia hạn, thanh toán...)
        adminRentalConnection.on("RentalUpdated", function (data) {
            if (!data || !data.transactionId) {
                location.reload();
                return;
            }
            showRealtimeToast(`Giao dịch #${data.transactionId} vừa được cập nhật!`, 'info');
            updateOfflineRowStatus(data.transactionId, data.status);
        });

        // Khi user báo mất sách - THÔNG BÁO NGAY cho admin
        adminRentalConnection.on("LostBookUpdated", function (data) {
            showRealtimeToast(`⚠️ ${data.message}`, 'warning');
            if (data.transactionId) {
                updateOfflineRowStatus(data.transactionId, 'Lost');
            }
        });

        // Khi số lượng sách thay đổi (trả hoặc mượn)
        adminRentalConnection.on("BookAvailabilityUpdated", function (data) {
            // Refresh page if book was returned (for reservation updates)
            // For targeted update, you could dispatch custom event
            console.log('Book availability updated:', data);
        });

        // Notification from server
        adminRentalConnection.on("ReceiveNotification", function (data) {
            if (data.type === 'LostBook' || data.type === 'Warning') {
                showRealtimeToast(`🔔 ${data.message}`, 'warning');
            }
        });

        adminRentalConnection.start()
            .then(() => console.log('SignalR connected for admin rentals'))
            .catch(err => console.error('SignalR error:', err));
    </script>
}
