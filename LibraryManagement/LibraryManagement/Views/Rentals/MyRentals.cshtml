<!-- Views/Rentals/MyRentals.cshtml -->
@model IEnumerable<LibraryManagement.Models.RentalTransaction>
@{
    ViewData["Title"] = "Sách đã thuê";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4"><i class="fas fa-book-reader"></i> Sách đã thuê của tôi</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tên sách</th>
                <th>Ngày thuê</th>
                <th>Hạn trả</th>
                <th>Ngày trả</th>
                <th>Giá thuê</th>
                <th>Phí trễ</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var rental in Model)
            {
                var isLost = rental.Status == "Lost";
                var isOverdue = rental.Status == "Renting" && rental.DueDate < DateTime.Now;
                var rowClass = isLost ? "table-secondary" : (isOverdue ? "table-danger" : (rental.Status == "Returned" ? "table-success" : ""));

                <tr class="@rowClass">
                    <td>@rental.Book.Title</td>
                    <td>@rental.RentalDate.ToString("dd/MM/yyyy")</td>
                    <td>@rental.DueDate.ToString("dd/MM/yyyy")</td>
                    <td>@(rental.ReturnDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>@rental.RentalPrice.ToString("N0") VND</td>
                    <td>
                        @if (rental.LateFee > 0)
                        {
                            <span class="text-danger">@rental.LateFee.ToString("N0") VND</span>
                        }
                        else
                        {
                            <span>0 VND</span>
                        }
                    </td>
                    <td><strong>@rental.TotalAmount.ToString("N0") VND</strong></td>
                    <td>
                        @if (rental.Status == "Renting")
                        {
                            if (isOverdue)
                            {
                                <span class="badge bg-danger">Quá hạn</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Đang thuê</span>
                            }
                        }
                        else if (rental.Status == "Returned")
                        {
                            <span class="badge bg-success">Đã trả</span>
                        }
                        else if (rental.Status == "Lost")
                        {
                            <span class="badge bg-dark">Đã báo mất</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">@rental.Status</span>
                        }
                    </td>
                    <td>
                        @if (rental.Status != "Returned" && rental.Status != "Lost")
                        {
                            <form asp-controller="Rentals" asp-action="ReportLost" method="post" class="d-inline" onsubmit="return confirm('Bạn xác nhận báo mất cuốn sách này? Thư viện sẽ thông báo cho quản trị viên.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="transactionId" value="@rental.TransactionId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-book-dead"></i> Báo mất
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <i class="fas fa-info-circle"></i> Bạn chưa thuê sách nào.
    </div>
}