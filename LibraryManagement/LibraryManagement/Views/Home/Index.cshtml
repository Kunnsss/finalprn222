<!-- Views/Home/Index.cshtml -->
@using LibraryManagement.Models
@model IEnumerable<LibraryManagement.Models.Book>

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="jumbotron bg-light p-5 rounded-3 mb-4">
    <h1 class="display-4">
        <i class="fas fa-book-reader"></i> Chào mừng đến với Thư viện
    </h1>
    <p class="lead">Hệ thống quản lý thư viện hiện đại với khả năng thuê sách vật lý và online</p>
    <hr class="my-4">
    <div class="row text-center">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h3>@ViewBag.TotalBooks</h3>
                    <p>Tổng số sách</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h3>@ViewBag.AvailableBooks</h3>
                    <p>Sách có sẵn</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h3>@ViewBag.ActiveRentals</h3>
                    <p>Đang cho thuê</p>
                </div>
            </div>
        </div>
    </div>
</div>

<h2 class="mb-4">
    <i class="fas fa-star"></i> Sách mới nhất
</h2>

<div class="row">
    @foreach (var book in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(book.CoverImage))
                {
                    <img src="@book.CoverImage" class="card-img-top" alt="@book.Title" style="height: 200px; object-fit: cover;">
                }
                else
                {
                    <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                        <i class="fas fa-book fa-4x text-white"></i>
                    </div>
                }

                <div class="card-body">
                    <h5 class="card-title">@book.Title</h5>
                    <p class="card-text">
                        <small class="text-muted">
                            <i class="fas fa-user"></i> @book.Author<br />
                            @if (book.IsPhysical)
                            {
                                <span class="badge bg-primary">Sách vật lý</span>
                                <span>@book.RentalPrice.ToString("N0") VND/ngày</span>
                            }
                            else
                            {
                                <span class="badge bg-info">Sách Online</span>
                                <span>@book.OnlinePrice?.ToString("N0") VND</span>
                            }
                        </small>
                    </p>
                </div>

                <div class="card-footer bg-transparent">
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId" class="btn btn-primary btn-sm w-100">
                        <i class="fas fa-info-circle"></i> Xem chi tiết
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<div class="text-center mt-4">
    <a asp-controller="Books" asp-action="Index" class="btn btn-primary btn-lg">
        <i class="fas fa-book"></i> Xem tất cả sách
    </a>
</div>