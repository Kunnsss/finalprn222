<!-- Views/Home/Index.cshtml -->
@using LibraryManagement.Models
@model IEnumerable<LibraryManagement.Models.Book>

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="lm-hero mb-4">
    <h1 class="h2 fw-bold mb-2" style="letter-spacing:-0.03em;">
        <i class="fas fa-book-reader text-primary"></i> Chào mừng đến thư viện
    </h1>
    <p class="text-muted mb-4 mb-md-5">Thuê sách vật lý &amp; online — giao diện gọn gàng, dễ tìm.</p>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="lm-stat">
                <h3>@ViewBag.TotalBooks</h3>
                <span class="text-muted small">Tổng số sách</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="lm-stat">
                <h3>@ViewBag.AvailableBooks</h3>
                <span class="text-muted small">Đang có sẵn</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="lm-stat">
                <h3>@ViewBag.ActiveRentals</h3>
                <span class="text-muted small">Đang cho thuê</span>
            </div>
        </div>
    </div>
</div>

<h2 class="h4 fw-bold mb-3" style="letter-spacing:-0.02em;">
    <i class="fas fa-star text-primary"></i> Sách mới nhất
</h2>

<div class="row g-3">
    @foreach (var book in Model)
    {
        <div class="col-6 col-md-4 col-lg-3">
            <article class="lm-book-card h-100 d-flex flex-column">
                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId" class="text-decoration-none text-dark">
                    @if (!string.IsNullOrEmpty(book.CoverImage))
                    {
                        <img src="@book.CoverImage" class="lm-book-cover" alt="@book.Title" loading="lazy" />
                    }
                    else
                    {
                        <div class="lm-book-cover placeholder">
                            <i class="fas fa-book"></i>
                        </div>
                    }
                    <div class="lm-book-body">
                        <h3 class="lm-book-title">@book.Title</h3>
                        <p class="lm-book-author mb-2">@book.Author</p>
                        <div class="lm-book-meta mb-0">
                            @if (book.IsPhysical)
                            {
                                <span class="badge bg-light text-dark border">Vật lý</span>
                                <span>@book.RentalPrice.ToString("N0") ₫/ngày</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-dark border">Online</span>
                                <span>@book.OnlinePrice?.ToString("N0") ₫</span>
                            }
                        </div>
                    </div>
                </a>
                <div class="lm-book-actions mt-auto">
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.BookId" class="btn btn-sm btn-primary w-100">
                        <i class="fas fa-info-circle"></i> Chi tiết
                    </a>
                </div>
            </article>
        </div>
    }
</div>

<div class="text-center mt-4 pt-2">
    <a asp-controller="Books" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4">
        <i class="fas fa-book"></i> Xem tất cả sách
    </a>
</div>
