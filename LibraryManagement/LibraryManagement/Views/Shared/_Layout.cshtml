<!-- Views/Shared/_Layout.cshtml - Improved -->
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thư Viện</title>

    <!-- Bootstrap CSS từ CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        /* ==================== CUSTOM ALERT STYLING ==================== */
        .alert {
            border-left: 4px solid;
            border-radius: 8px;
            animation: slideInDown 0.3s ease-out;
        }

        .alert-success {
            border-left-color: #198754;
            background-color: #d1e7dd;
        }

        .alert-danger {
            border-left-color: #dc3545;
            background-color: #f8d7da;
        }

        .alert-info {
            border-left-color: #0dcaf0;
            background-color: #cff4fc;
        }

        .alert-warning {
            border-left-color: #ffc107;
            background-color: #fff3cd;
        }

        .alert .alert-heading {
            font-weight: 600;
            font-size: 1.1rem;
        }

        @@keyframes slideInDown {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .alert.fade-out {
            animation: fadeOut 0.5s ease-out forwards;
        }

        @@keyframes fadeOut {
            from {
                opacity: 1;
            }

            to {
                opacity: 0;
                transform: translateY(-10px);
            }
        }

        /* ==================== CUSTOM CONFIRMATION MODAL ==================== */
        .custom-confirm-modal .modal-content {
            border-radius: 15px;
            border: none;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        .custom-confirm-modal .modal-header {
            background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
            color: white;
            border-radius: 15px 15px 0 0;
            border: none;
        }

        .custom-confirm-modal .modal-body {
            padding: 30px;
            font-size: 1.1rem;
        }

        .custom-confirm-modal .btn-custom-confirm {
            background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
            border: none;
            padding: 10px 30px;
            border-radius: 25px;
            color: white;
            font-weight: 600;
            transition: transform 0.2s;
        }

            .custom-confirm-modal .btn-custom-confirm:hover {
                transform: scale(1.05);
            }

        .custom-confirm-modal .btn-custom-cancel {
            background: #6c757d;
            border: none;
            padding: 10px 30px;
            border-radius: 25px;
            color: white;
            font-weight: 600;
            transition: transform 0.2s;
        }

            .custom-confirm-modal .btn-custom-cancel:hover {
                transform: scale(1.05);
            }

        .notification-item {
            padding: 10px;
            border-bottom: 1px solid #eee;
            transition: background-color 0.2s;
        }

            .notification-item:hover {
                background-color: #f1f5f9;
            }

            .notification-item:last-child {
                border-bottom: none;
            }

            .notification-item.unread {
                background-color: #ccfbf1;
            }

        .dropdown-menu {
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
        }

        .modal-content {
            border-radius: 12px;
            border: 1px solid #e2e8f0;
        }

        #notificationBell {
            cursor: pointer;
        }
    </style>
</head>
<body>
    @{
        var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var act = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        string NavActive(string c, string a) =>
            string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(act, a, StringComparison.OrdinalIgnoreCase) ? "active" : "";
        string NavActiveController(string c) =>
            string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }
    <div class="app-shell">
        <aside class="sidebar" id="appSidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <i class="fas fa-book-open"></i> Thư Viện
            </a>
            <div class="sidebar-scroll">
                <p class="nav-section-label">Thư viện</p>
                <a class="sidebar-link @NavActive("Home","Index")" asp-controller="Home" asp-action="Index" data-sidebar-close>
                    <i class="fas fa-home"></i> Trang chủ
                </a>
                <a class="sidebar-link @NavActiveController("Books")" asp-controller="Books" asp-action="Index" data-sidebar-close>
                    <i class="fas fa-book"></i> Sách
                </a>

                @if (User.Identity.IsAuthenticated)
                {
                    <p class="nav-section-label">Cá nhân</p>
                    <div class="sidebar-sub">
                        <a class="sidebar-link @NavActive("Rentals","MyRentals")" asp-controller="Rentals" asp-action="MyRentals" data-sidebar-close>
                            <i class="fas fa-bookmark"></i> Sách đã thuê
                        </a>
                        <a class="sidebar-link @NavActive("OnlineRentals","MyOnlineRentals")" asp-controller="OnlineRentals" asp-action="MyOnlineRentals" data-sidebar-close>
                            <i class="fas fa-laptop"></i> Sách online
                        </a>
                        <a class="sidebar-link @NavActive("BookReservation","MyReservations")" asp-controller="BookReservation" asp-action="MyReservations" data-sidebar-close>
                            <i class="fas fa-calendar-check"></i> Đặt chỗ
                        </a>
                        <a class="sidebar-link @NavActive("Events","MyEvents")" asp-controller="Events" asp-action="MyEvents" data-sidebar-close>
                            <i class="fas fa-list-alt"></i> Sự kiện của tôi
                        </a>
                        <a class="sidebar-link @NavActive("Wishlist","Index")" asp-controller="Wishlist" asp-action="Index" data-sidebar-close>
                            <i class="fas fa-heart"></i> Yêu thích
                        </a>
                        <a class="sidebar-link @NavActive("ReadingHistory","Index")" asp-controller="ReadingHistory" asp-action="Index" data-sidebar-close>
                            <i class="fas fa-history"></i> Đã đọc
                        </a>
                    </div>

                    <p class="nav-section-label">Khám phá</p>
                    <a class="sidebar-link @NavActive("Events","Index")" asp-controller="Events" asp-action="Index" data-sidebar-close>
                        <i class="fas fa-calendar-alt"></i> Sự kiện
                    </a>
                    <a class="sidebar-link @NavActive("Announcements","Index")" asp-controller="Announcements" asp-action="Index" data-sidebar-close>
                        <i class="fas fa-bullhorn"></i> Thông báo hệ thống
                    </a>

                    @if (!(User.IsInRole("Admin") || User.IsInRole("Librarian")))
                    {
                        <a class="sidebar-link @NavActive("Support","Chat")" asp-controller="Support" asp-action="Chat" data-sidebar-close>
                            <i class="fas fa-comments"></i> Hỗ trợ
                        </a>
                    }
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                {
                    <p class="nav-section-label">Quản lý</p>
                    <div class="sidebar-sub">
                        <a class="sidebar-link @NavActive("Dashboard","Index")" asp-controller="Dashboard" asp-action="Index" data-sidebar-close>
                            <i class="fas fa-chart-line"></i> Dashboard
                        </a>
                        <a class="sidebar-link @NavActive("Books","Create")" asp-controller="Books" asp-action="Create" data-sidebar-close>
                            <i class="fas fa-plus-circle"></i> Thêm sách
                        </a>
                        <a class="sidebar-link @NavActive("Rentals","AllRentals")" asp-controller="Rentals" asp-action="AllRentals" data-sidebar-close>
                            <i class="fas fa-list"></i> Tất cả giao dịch
                        </a>
                        <a class="sidebar-link @NavActive("Rentals","OverdueRentals")" asp-controller="Rentals" asp-action="OverdueRentals" data-sidebar-close>
                            <i class="fas fa-exclamation-triangle"></i> Sách quá hạn
                        </a>
                        <a class="sidebar-link @NavActive("BookReservation","ManageReservations")" asp-controller="BookReservation" asp-action="ManageReservations" data-sidebar-close>
                            <i class="fas fa-clock"></i> Quản lý đặt chỗ
                        </a>
                        <a class="sidebar-link @NavActive("Support","ManageChats")" asp-controller="Support" asp-action="ManageChats" data-sidebar-close>
                            <i class="fas fa-headset"></i> Quản lý hỗ trợ
                        </a>
                        <a class="sidebar-link @NavActive("UserManagement","Index")" asp-controller="UserManagement" asp-action="Index" data-sidebar-close>
                            <i class="fas fa-users-cog"></i> Tài khoản
                        </a>
                    </div>
                }
            </div>

            <div class="sidebar-footer">
                @if (!User.Identity.IsAuthenticated)
                {
                    <a class="sidebar-link @NavActive("Account","Login")" asp-controller="Account" asp-action="Login" data-sidebar-close>
                        <i class="fas fa-sign-in-alt"></i> Đăng nhập
                    </a>
                    <a class="sidebar-link @NavActive("Account","Register")" asp-controller="Account" asp-action="Register" data-sidebar-close>
                        <i class="fas fa-user-plus"></i> Đăng ký
                    </a>
                }
                else
                {
                    <small class="text-muted d-block px-2 mb-1">@User.FindFirst("FullName")?.Value</small>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="sidebar-link border-0 bg-transparent w-100 text-start">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </button>
                    </form>
                }
            </div>
        </aside>

        <div class="sidebar-backdrop d-lg-none" id="sidebarBackdrop" aria-hidden="true"></div>

        <div class="main-wrap">
            <header class="top-bar">
                <button type="button" class="btn btn-icon d-lg-none" id="sidebarToggle" aria-label="Mở menu">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="top-bar-title d-none d-sm-inline">@ViewData["Title"]</span>
                <div class="top-bar-actions ms-auto">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a class="nav-link" href="#" id="notificationBell" title="Thông báo">
                            <i class="fas fa-bell fa-lg"></i>
                            <span class="badge bg-danger" id="notificationCount" style="display:none;">0</span>
                        </a>
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-circle fa-lg"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <span class="dropdown-item-text small text-muted">
                                        <i class="fas fa-id-badge"></i>
                                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        <i class="fas fa-user"></i> Hồ sơ
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </header>

            <div class="content-area">
        @* ==================== IMPROVED ALERTS ==================== *@
        @if (TempData["SuccessMessage"] != null)
        {
            var message = TempData["SuccessMessage"].ToString();
            message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
            message = message.Trim();

            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading mb-1">Thành công!</h5>
                        <p class="mb-0">@message</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            var message = TempData["ErrorMessage"].ToString();
            message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
            message = message.Trim();

            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-circle fa-2x me-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading mb-1">Có lỗi xảy ra!</h5>
                        <p class="mb-0">@message</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            var message = TempData["InfoMessage"].ToString();
            message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
            message = message.Trim();

            <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-info-circle fa-2x me-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading mb-1">Thông báo</h5>
                        <p class="mb-0">@message</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

                <main role="main">
                    @RenderBody()
                </main>
            </div>

            <footer class="app-footer">
                <span><i class="fas fa-book-reader"></i> &copy; 2026 — Hệ thống quản lý thư viện</span>
            </footer>
        </div>
    </div>


    <div id="forceLogoutOverlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:99999; justify-content:center; align-items:center;">
        <div style="background:white; border-radius:16px; padding:40px; max-width:420px; width:90%; text-align:center;">
            <i class="fas fa-user-slash fa-3x text-danger mb-3"></i>
            <h4 class="text-danger fw-bold">Tài khoản bị đăng xuất</h4>
            <p class="text-muted">Quản trị viên đã buộc đăng xuất tài khoản của bạn.</p>
            <div style="background:#fff3cd; border-left:4px solid #ffc107; border-radius:8px; padding:12px 16px; margin:16px 0; text-align:left;">
                <strong><i class="fas fa-comment-alt me-1"></i> Lý do:</strong>
                <div id="forceLogoutReason" class="mt-1"></div>
            </div>
            <p class="text-muted mb-1">Tự động chuyển hướng sau</p>
            <div id="forceLogoutCountdown" style="font-size:2rem; font-weight:700; color:#dc3545;">5</div>
            <p class="text-muted">giây...</p>
        </div>
    </div>

    @* ==================== CUSTOM CONFIRMATION MODAL ==================== *@
    <div class="modal fade custom-confirm-modal" id="globalConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-question-circle"></i> <span id="confirmTitle">Xác nhận</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <i id="confirmIcon" class="fas fa-question-circle fa-3x text-primary mb-3"></i>
                    <p id="confirmMessage" class="mb-0">Bạn có chắc chắn muốn thực hiện hành động này?</p>
                    <small class="text-muted">Hành động này có thể không thể hoàn tác</small>
                </div>
                <div class="modal-footer justify-content-center border-0">
                    <button type="button" class="btn btn-custom-cancel" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Hủy
                    </button>
                    <button type="button" class="btn btn-custom-confirm" id="globalConfirmBtn">
                        <i class="fas fa-check"></i> Xác nhận
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header text-white" style="background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);">
                    <h5 class="modal-title">
                        <i class="fas fa-bell"></i> Thông báo
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0" id="notificationList" style="max-height: 400px;">
                    <div class="p-4 text-center text-muted">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p>Không có thông báo mới</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="markAllAsRead()">
                        <i class="fas fa-check-double"></i> Đánh dấu đã đọc
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts từ CDN -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>

    <script>
        // ==================== GLOBAL CONFIRM FUNCTIONALITY ====================
        let globalConfirmCallback = null;

        // Override window.confirm to use our custom modal
        window.customConfirm = function(message, title = "Xác nhận", icon = "fa-question-circle") {
            return new Promise((resolve) => {
                document.getElementById('confirmTitle').textContent = title;
                document.getElementById('confirmMessage').textContent = message;
                document.getElementById('confirmIcon').className = `fas ${icon} fa-3x text-primary mb-3`;

                globalConfirmCallback = resolve;
                const modal = new bootstrap.Modal(document.getElementById('globalConfirmModal'));
                modal.show();
            });
        };

        document.getElementById('globalConfirmBtn').addEventListener('click', function() {
            if (globalConfirmCallback) {
                globalConfirmCallback(true);
                globalConfirmCallback = null;
            }
            bootstrap.Modal.getInstance(document.getElementById('globalConfirmModal')).hide();
        });

        document.getElementById('globalConfirmModal').addEventListener('hidden.bs.modal', function() {
            if (globalConfirmCallback) {
                globalConfirmCallback(false);
                globalConfirmCallback = null;
            }
        });

        // Auto-handle all forms with data-confirm attribute
        document.addEventListener('submit', async function(e) {
            const form = e.target;
            if (form.hasAttribute('data-confirm')) {
                e.preventDefault();
                const message = form.getAttribute('data-confirm');
                const confirmed = await customConfirm(message, 'Xác nhận', 'fa-question-circle');
                if (confirmed) {
                    form.removeAttribute('data-confirm');
                    form.submit();
                }
            }
        });

        // Auto-handle all buttons with data-confirm attribute
        document.addEventListener('click', async function(e) {
            const btn = e.target.closest('[data-confirm]');
            if (btn && !btn.form) {
                e.preventDefault();
                const message = btn.getAttribute('data-confirm');
                const confirmed = await customConfirm(message, 'Xác nhận', 'fa-question-circle');
                if (confirmed) {
                    if (btn.form) {
                        btn.form.submit();
                    } else if (btn.hasAttribute('onclick')) {
                        btn.removeAttribute('data-confirm');
                        btn.click();
                    }
                }
            }
        });

        // ==================== SIDEBAR (mobile) ====================
        (function () {
            const toggle = document.getElementById('sidebarToggle');
            const backdrop = document.getElementById('sidebarBackdrop');
            function close() { document.body.classList.remove('sidebar-open'); }
            function open() { document.body.classList.add('sidebar-open'); }
            toggle?.addEventListener('click', function () {
                if (document.body.classList.contains('sidebar-open')) close(); else open();
            });
            backdrop?.addEventListener('click', close);
            document.querySelectorAll('[data-sidebar-close]').forEach(function (el) {
                el.addEventListener('click', function () {
                    if (window.innerWidth < 992) close();
                });
            });
            window.addEventListener('resize', function () {
                if (window.innerWidth >= 992) close();
            });
        })();

        // ==================== AUTO-HIDE ALERTS ====================
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').addClass('fade-out');
                setTimeout(function() {
                    $('.alert').alert('close');
                }, 500);
            }, 6000);

            $('.alert').on('click', function() {
                $(this).addClass('fade-out');
                var alert = $(this);
                setTimeout(function() {
                    alert.alert('close');
                }, 500);
            });
        });
    </script>

    @if (User.Identity.IsAuthenticated)
    {
        <script>
            // SignalR Connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/libraryHub")
                .build();

            connection.on("ReceiveNotification", function (notification) {
                updateNotificationCount(1);
                showToast(notification.message, notification.type);
            });

            connection.on("BookNowAvailable", function (data) {
                updateNotificationCount(1);
                showToast(data.message, "BookAvailable");
            });

            connection.on("SystemMessage", function (data) {
                showSystemMessage(data.title, data.message, data.type);
            });

            connection.on("NewEventCreated", function (data) {
                showToast(data.message, "Info");
            });

            connection.on("EventCancelled", function (data) {
                showToast(`Sự kiện "${data.eventName}" đã bị hủy. Lý do: ${data.reason}`, "Warning");
            });

            connection.on("ForceLogout", function (data) {
            const reason = data.reason || "Không có lý do cụ thể";

            document.getElementById('forceLogoutReason').textContent = reason;
            document.getElementById('forceLogoutOverlay').style.display = 'flex';

            let seconds = 5;
            const countdownEl = document.getElementById('forceLogoutCountdown');

            const timer = setInterval(function () {
            seconds--;
            countdownEl.textContent = seconds;
            if (seconds <= 0) {
            clearInterval(timer);
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Account/Logout';
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
            const hiddenToken = document.createElement('input');
            hiddenToken.type = 'hidden';
            hiddenToken.name = '__RequestVerificationToken';
            hiddenToken.value = token.value;
            form.appendChild(hiddenToken);
            }
            document.body.appendChild(form);
            form.submit();
            }
            }, 1000);
            });

            connection.start()
                .then(() => {
                    console.log('SignalR Connected');
                    loadNotificationCount();
                })
                .catch(err => console.error('SignalR Error:', err.toString()));

            function loadNotificationCount() {
                fetch('/Notifications/GetUnreadCount')
                    .then(res => res.json())
                    .then(count => {
                        if (count > 0) {
                            updateNotificationCount(count, true);
                        }
                    })
                    .catch(err => console.error('Error loading notification count:', err));
            }

            function updateNotificationCount(increment, setAbsolute = false) {
                const countBadge = document.getElementById("notificationCount");
                if (setAbsolute) {
                    countBadge.textContent = increment;
                } else {
                    let currentCount = parseInt(countBadge.textContent) || 0;
                    countBadge.textContent = currentCount + increment;
                }

                if (parseInt(countBadge.textContent) > 0) {
                    countBadge.style.display = "inline";
                } else {
                    countBadge.style.display = "none";
                }
            }

            document.getElementById("notificationBell")?.addEventListener("click", function(e) {
                e.preventDefault();
                loadNotifications();
                const modal = new bootstrap.Modal(document.getElementById('notificationModal'));
                modal.show();
            });

            function loadNotifications() {
                fetch('/Notifications/GetMyNotifications')
                    .then(res => res.json())
                    .then(notifications => {
                        const listDiv = document.getElementById("notificationList");

                        if (notifications.length === 0) {
                            listDiv.innerHTML = `
                                <div class="p-4 text-center text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3"></i>
                                    <p>Không có thông báo mới</p>
                                </div>`;
                            return;
                        }

                        const html = notifications.map(n => {
                            const typeIcon = n.type === "Success" ? "fa-check-circle text-success" :
                                           n.type === "Overdue" ? "fa-exclamation-triangle text-danger" :
                                           n.type === "LostBook" ? "fa-book-dead text-dark" :
                                           n.type === "BookAvailable" ? "fa-book text-info" :
                                           "fa-info-circle text-primary";

                            const timeAgo = getTimeAgo(new Date(n.createdDate));
                            const unreadClass = n.isRead ? "" : "unread";

                            return `
                                <div class="notification-item ${unreadClass}" data-id="${n.notificationId}">
                                    <div class="d-flex">
                                        <div class="me-3">
                                            <i class="fas ${typeIcon} fa-lg"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <p class="mb-1">${n.message}</p>
                                            <small class="text-muted">${timeAgo}</small>
                                        </div>
                                    </div>
                                </div>`;
                        }).join('');

                        listDiv.innerHTML = html;
                        document.getElementById("notificationCount").style.display = "none";
                    })
                    .catch(err => console.error('Error loading notifications:', err));
            }

            function markAllAsRead() {
                fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                    .then(() => {
                        loadNotifications();
                        document.getElementById("notificationCount").style.display = "none";
                    })
                    .catch(err => console.error('Error marking as read:', err));
            }

            function getTimeAgo(date) {
                const seconds = Math.floor((new Date() - date) / 1000);
                if (seconds < 60) return 'Vừa xong';
                if (seconds < 3600) return Math.floor(seconds / 60) + ' phút trước';
                if (seconds < 86400) return Math.floor(seconds / 3600) + ' giờ trước';
                return Math.floor(seconds / 86400) + ' ngày trước';
            }

            function showToast(message, type) {
                const alertClass = type === "Success" ? "alert-success" :
                                 type === "Overdue" ? "alert-danger" :
                                 type === "LostBook" ? "alert-dark" :
                                 type === "Warning" ? "alert-warning" :
                                 type === "BookAvailable" ? "alert-info" :
                                 "alert-info";

                const iconClass = type === "Success" ? "fa-check-circle" :
                                type === "Overdue" ? "fa-exclamation-triangle" :
                                type === "LostBook" ? "fa-book-dead" :
                                type === "Warning" ? "fa-exclamation-circle" :
                                type === "BookAvailable" ? "fa-book" :
                                "fa-info-circle";

                const toast = `<div class="alert ${alertClass} alert-dismissible fade show position-fixed top-0 end-0 m-3" role="alert" style="z-index:9999; min-width: 300px;">
                    <i class="fas ${iconClass}"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;

                document.body.insertAdjacentHTML('beforeend', toast);

                setTimeout(() => {
                    const alerts = document.querySelectorAll('.alert.position-fixed');
                    if (alerts.length > 0) {
                        alerts[alerts.length - 1]?.remove();
                    }
                }, 5000);
            }

            function showSystemMessage(title, message, type) {
                const alertClass = type === "Alert" ? "alert-danger" :
                                 type === "Warning" ? "alert-warning" :
                                 "alert-info";

                const toast = `<div class="alert ${alertClass} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x m-3" role="alert" style="z-index:9999; min-width: 400px;">
                    <h5 class="alert-heading"><i class="fas fa-bullhorn"></i> ${title}</h5>
                    <p class="mb-0">${message}</p>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;

                document.body.insertAdjacentHTML('beforeend', toast);

                setTimeout(() => {
                    const alerts = document.querySelectorAll('.alert.position-fixed');
                    if (alerts.length > 0) {
                        alerts[0]?.remove();
                    }
                }, 10000);
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
