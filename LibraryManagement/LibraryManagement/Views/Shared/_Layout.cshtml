    <div class="container my-4">
        @* ==================== IMPROVED ALERTS ==================== *@
        @if (TempData["SuccessMessage"] != null)
        {
            var message = TempData["SuccessMessage"].ToString();
            message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
            message = message.Trim();

            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-check-circle fa-2x me-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading mb-1">Thành công!</h5>
                        <p class="mb-0">@message</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            var message = TempData["ErrorMessage"].ToString();
            message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
            message = message.Trim();

            <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-exclamation-circle fa-2x me-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading mb-1">Có lỗi xảy ra!</h5>
                        <p class="mb-0">@message</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            var message = TempData["InfoMessage"].ToString();
            message = System.Text.RegularExpressions.Regex.Replace(message, @"https?://localhost:\d+[^\s]*", "");
            message = message.Trim();

            <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="fas fa-info-circle fa-2x me-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h5 class="alert-heading mb-1">Thông báo</h5>
                        <p class="mb-0">@message</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }

        <main role="main">
            @RenderBody()
        </main>
    </div>

    @* ==================== CUSTOM CONFIRMATION MODAL ==================== *@
    <div class="modal fade custom-confirm-modal" id="globalConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-question-circle"></i> <span id="confirmTitle">Xác nhận</span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                    <i id="confirmIcon" class="fas fa-question-circle fa-3x text-primary mb-3"></i>
                    <p id="confirmMessage" class="mb-0">Bạn có chắc chắn muốn thực hiện hành động này?</p>
                    <small class="text-muted">Hành động này có thể không thể hoàn tác</small>
                </div>
                <div class="modal-footer justify-content-center border-0">
                    <button type="button" class="btn btn-custom-cancel" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Hủy
                    </button>
                    <button type="button" class="btn btn-custom-confirm" id="globalConfirmBtn">
                        <i class="fas fa-check"></i> Xác nhận
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Notification Modal -->
    <div class="modal fade" id="notificationModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="fas fa-bell"></i> Thông báo
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0" id="notificationList" style="max-height: 400px;">
                    <div class="p-4 text-center text-muted">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p>Không có thông báo mới</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="markAllAsRead()">
                        <i class="fas fa-check-double"></i> Đánh dấu đã đọc
                    </button>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer mt-auto py-1">
        <div class="container text-center">
            <span class="text-muted">
                <i class="fas fa-book-reader"></i> &copy; 2026 - Hệ thống quản lý thư viện
            </span>
        </div>
    </footer>

    <!-- Scripts từ CDN -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>

    <script>
        // ==================== GLOBAL CONFIRM FUNCTIONALITY ====================
        let globalConfirmCallback = null;

        // Override window.confirm to use our custom modal
        window.customConfirm = function(message, title = "Xác nhận", icon = "fa-question-circle") {
            return new Promise((resolve) => {
                document.getElementById('confirmTitle').textContent = title;
                document.getElementById('confirmMessage').textContent = message;
                document.getElementById('confirmIcon').className = `fas ${icon} fa-3x text-primary mb-3`;

                globalConfirmCallback = resolve;
                const modal = new bootstrap.Modal(document.getElementById('globalConfirmModal'));
                modal.show();
            });
        };

        document.getElementById('globalConfirmBtn').addEventListener('click', function() {
            if (globalConfirmCallback) {
                globalConfirmCallback(true);
                globalConfirmCallback = null;
            }
            bootstrap.Modal.getInstance(document.getElementById('globalConfirmModal')).hide();
        });

        document.getElementById('globalConfirmModal').addEventListener('hidden.bs.modal', function() {
            if (globalConfirmCallback) {
                globalConfirmCallback(false);
                globalConfirmCallback = null;
            }
        });

        // Auto-handle all forms with data-confirm attribute
        document.addEventListener('submit', async function(e) {
            const form = e.target;
            if (form.hasAttribute('data-confirm')) {
                e.preventDefault();
                const message = form.getAttribute('data-confirm');
                const confirmed = await customConfirm(message, 'Xác nhận', 'fa-question-circle');
                if (confirmed) {
                    form.removeAttribute('data-confirm');
                    form.submit();
                }
            }
        });

        // Auto-handle all buttons with data-confirm attribute
        document.addEventListener('click', async function(e) {
            const btn = e.target.closest('[data-confirm]');
            if (btn && !btn.form) {
                e.preventDefault();
                const message = btn.getAttribute('data-confirm');
                const confirmed = await customConfirm(message, 'Xác nhận', 'fa-question-circle');
                if (confirmed) {
                    if (btn.form) {
                        btn.form.submit();
                    } else if (btn.hasAttribute('onclick')) {
                        btn.removeAttribute('data-confirm');
                        btn.click();
                    }
                }
            }
        });

        // ==================== AUTO-HIDE ALERTS ====================
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').addClass('fade-out');
                setTimeout(function() {
                    $('.alert').alert('close');
                }, 500);
            }, 6000);

            $('.alert').on('click', function() {
                $(this).addClass('fade-out');
                var alert = $(this);
                setTimeout(function() {
                    alert.alert('close');
                }, 500);
            });
        });
    </script>

    @if (User.Identity.IsAuthenticated)
    {
        <script>
            // SignalR Connection
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/libraryHub")
                .build();

            connection.on("ReceiveNotification", function (notification) {
                updateNotificationCount(1);
                showToast(notification.message, notification.type);
            });

            connection.on("BookNowAvailable", function (data) {
                updateNotificationCount(1);
                showToast(data.message, "BookAvailable");
            });

            connection.on("SystemMessage", function (data) {
                showSystemMessage(data.title, data.message, data.type);
            });

            connection.on("NewEventCreated", function (data) {
                showToast(data.message, "Info");
            });

            connection.on("EventCancelled", function (data) {
                showToast(`Sự kiện "${data.eventName}" đã bị hủy. Lý do: ${data.reason}`, "Warning");
            });

            connection.start()
                .then(() => {
                    console.log('SignalR Connected');
                    loadNotificationCount();
                })
                .catch(err => console.error('SignalR Error:', err.toString()));

            function loadNotificationCount() {
                fetch('/Notifications/GetUnreadCount')
                    .then(res => res.json())
                    .then(count => {
                        if (count > 0) {
                            updateNotificationCount(count, true);
                        }
                    })
                    .catch(err => console.error('Error loading notification count:', err));
            }

            function updateNotificationCount(increment, setAbsolute = false) {
                const countBadge = document.getElementById("notificationCount");
                if (setAbsolute) {
                    countBadge.textContent = increment;
                } else {
                    let currentCount = parseInt(countBadge.textContent) || 0;
                    countBadge.textContent = currentCount + increment;
                }

                if (parseInt(countBadge.textContent) > 0) {
                    countBadge.style.display = "inline";
                } else {
                    countBadge.style.display = "none";
                }
            }

            document.getElementById("notificationBell")?.addEventListener("click", function(e) {
                e.preventDefault();
                loadNotifications();
                const modal = new bootstrap.Modal(document.getElementById('notificationModal'));
                modal.show();
            });

            function loadNotifications() {
                fetch('/Notifications/GetMyNotifications')
                    .then(res => res.json())
                    .then(notifications => {
                        const listDiv = document.getElementById("notificationList");

                        if (notifications.length === 0) {
                            listDiv.innerHTML = `
                                <div class="p-4 text-center text-muted">
                                    <i class="fas fa-inbox fa-3x mb-3"></i>
                                    <p>Không có thông báo mới</p>
                                </div>`;
                            return;
                        }

                        const html = notifications.map(n => {
                            const typeIcon = n.type === "Success" ? "fa-check-circle text-success" :
                                           n.type === "Overdue" ? "fa-exclamation-triangle text-danger" :
                                           n.type === "BookAvailable" ? "fa-book text-info" :
                                           "fa-info-circle text-primary";

                            const timeAgo = getTimeAgo(new Date(n.createdDate));
                            const unreadClass = n.isRead ? "" : "unread";

                            return `
                                <div class="notification-item ${unreadClass}" data-id="${n.notificationId}">
                                    <div class="d-flex">
                                        <div class="me-3">
                                            <i class="fas ${typeIcon} fa-lg"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <p class="mb-1">${n.message}</p>
                                            <small class="text-muted">${timeAgo}</small>
                                        </div>
                                    </div>
                                </div>`;
                        }).join('');

                        listDiv.innerHTML = html;
                        document.getElementById("notificationCount").style.display = "none";
                    })
                    .catch(err => console.error('Error loading notifications:', err));
            }

            function markAllAsRead() {
                fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                    .then(() => {
                        loadNotifications();
                        document.getElementById("notificationCount").style.display = "none";
                    })
                    .catch(err => console.error('Error marking as read:', err));
            }

            function getTimeAgo(date) {
                const seconds = Math.floor((new Date() - date) / 1000);
                if (seconds < 60) return 'Vừa xong';
                if (seconds < 3600) return Math.floor(seconds / 60) + ' phút trước';
                if (seconds < 86400) return Math.floor(seconds / 3600) + ' giờ trước';
                return Math.floor(seconds / 86400) + ' ngày trước';
            }

            function showToast(message, type) {
                const alertClass = type === "Success" ? "alert-success" :
                                 type === "Overdue" ? "alert-danger" :
                                 type === "Warning" ? "alert-warning" :
                                 type === "BookAvailable" ? "alert-info" :
                                 "alert-info";

                const iconClass = type === "Success" ? "fa-check-circle" :
                                type === "Overdue" ? "fa-exclamation-triangle" :
                                type === "Warning" ? "fa-exclamation-circle" :
                                type === "BookAvailable" ? "fa-book" :
                                "fa-info-circle";

                const toast = `<div class="alert ${alertClass} alert-dismissible fade show position-fixed top-0 end-0 m-3" role="alert" style="z-index:9999; min-width: 300px;">
                    <i class="fas ${iconClass}"></i> ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;

                document.body.insertAdjacentHTML('beforeend', toast);

                setTimeout(() => {
                    const alerts = document.querySelectorAll('.alert.position-fixed');
                    if (alerts.length > 0) {
                        alerts[alerts.length - 1]?.remove();
                    }
                }, 5000);
            }

            function showSystemMessage(title, message, type) {
                const alertClass = type === "Alert" ? "alert-danger" :
                                 type === "Warning" ? "alert-warning" :
                                 "alert-info";

                const toast = `<div class="alert ${alertClass} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x m-3" role="alert" style="z-index:9999; min-width: 400px;">
                    <h5 class="alert-heading"><i class="fas fa-bullhorn"></i> ${title}</h5>
                    <p class="mb-0">${message}</p>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;

                document.body.insertAdjacentHTML('beforeend', toast);

                setTimeout(() => {
                    const alerts = document.querySelectorAll('.alert.position-fixed');
                    if (alerts.length > 0) {
                        alerts[0]?.remove();
                    }
                }, 10000);
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
