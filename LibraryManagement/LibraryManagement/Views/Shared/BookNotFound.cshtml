<!-- Views/Shared/BookNotFound.cshtml -->
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Không tìm thấy sách";
}

<div class="container text-center py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <i class="fas fa-book-open text-danger" style="font-size: 80px;"></i>
                    </div>
                    <h1 class="display-4 text-danger mb-3">404</h1>
                    <h2 class="mb-4">Sách không tồn tại</h2>
                    <p class="text-muted mb-4">
                        Xin lỗi, sách bạn đang tìm kiếm không tồn tại hoặc đã bị xóa khỏi hệ thống.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-home"></i> Về trang chủ
                        </a>
                        <a asp-controller="Books" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-book"></i> Xem danh sách sách
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
