@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Không tìm thấy sách";
}

<div class="lm-empty py-5 px-3" style="max-width: 520px; margin: 0 auto;">
    <div class="rounded-4 p-4 p-md-5 bg-white border" style="border-color: var(--lm-border) !important;">
        <div class="text-primary mb-3" style="font-size: 3.5rem;">
            <i class="fas fa-book-open"></i>
        </div>
        <h1 class="h2 fw-bold mb-2" style="letter-spacing:-0.03em;">Không tìm thấy sách</h1>
        <p class="text-muted mb-4">
            Sách bạn mở có thể đã bị xóa hoặc mã không hợp lệ.
        </p>
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <a asp-controller="Books" asp-action="Index" class="btn btn-primary rounded-pill px-4">
                <i class="fas fa-book"></i> Về kho sách
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="fas fa-home"></i> Trang chủ
            </a>
        </div>
    </div>
</div>
