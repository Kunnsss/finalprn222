@* Views/Account/ForgotPassword.cshtml *@
@model LibraryManagement.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">
                    <i class="fas fa-key"></i> Quên mật khẩu
                </h4>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i>
                    <strong>Xác thực tài khoản</strong>
                    <p class="mb-0 mt-2">
                        Vui lòng nhập chính xác <strong>tên đăng nhập</strong>, <strong>email</strong>
                        và <strong>số điện thoại</strong> đã đăng ký để xác thực tài khoản của bạn.
                    </p>
                </div>

                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <!-- Username -->
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">
                            <i class="fas fa-user"></i> Tên đăng nhập <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Username" class="form-control"
                               placeholder="Nhập tên đăng nhập của bạn"
                               autofocus />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">
                            <i class="fas fa-envelope"></i> Email <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Email" class="form-control"
                               placeholder="Nhập email đã đăng ký"
                               type="email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Phone Number -->
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">
                            <i class="fas fa-phone"></i> Số điện thoại <span class="text-danger">*</span>
                        </label>
                        <input asp-for="PhoneNumber" class="form-control"
                               placeholder="Nhập số điện thoại đã đăng ký"
                               type="tel" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        <small class="text-muted">
                            <i class="fas fa-shield-alt"></i>
                            Số điện thoại được dùng để xác thực tài khoản của bạn
                        </small>
                    </div>

                    <!-- Buttons -->
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-check-circle"></i> Xác thực tài khoản
                        </button>
                        <a asp-action="Login" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Quay lại đăng nhập
                        </a>
                    </div>
                </form>

                <hr class="my-4" />

                <!-- Security Tips -->
                <div class="card bg-light">
                    <div class="card-body">
                        <h6 class="card-title">
                            <i class="fas fa-lightbulb text-warning"></i>
                            Lời khuyên bảo mật
                        </h6>
                        <ul class="small mb-0">
                            <li>Chỉ sử dụng tính năng này khi bạn thực sự quên mật khẩu</li>
                            <li>Đảm bảo thông tin email và số điện thoại luôn được cập nhật</li>
                            <li>Không chia sẻ thông tin đăng nhập với người khác</li>
                            <li>Nếu không phải bạn thực hiện, vui lòng liên hệ admin ngay</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
